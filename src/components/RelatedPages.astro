---
import { computeRelated } from '../lib/relations';

interface Props {
  currentPage: { id: string; data: { title: string; section: string; seo_keywords?: string[]; funnel_level: number } };
  allPages: Array<{ id: string; data: { title: string; section: string; seo_keywords?: string[]; funnel_level: number; see_also?: string[] } }>;
  seeAlso?: string[];
  lang?: 'en' | 'pl';
}

const { currentPage, allPages, seeAlso = [], lang = 'en' } = Astro.props;
const prefix = lang === 'pl' ? '/pl/' : '/';

// Prioritize see_also (manual curation), then fill with computed
const seeAlsoPages = seeAlso
  .map(slug => allPages.find(p => p.id === slug || p.id.endsWith('/' + slug)))
  .filter((p): p is typeof allPages[number] => p != null && p.id !== currentPage.id);

const computed = computeRelated(currentPage, allPages);
const computedFiltered = computed.filter(p => !seeAlsoPages.some(s => s.id === p.id));
const related = [...seeAlsoPages, ...computedFiltered].slice(0, 5);
---

{related.length > 0 && (
  <div class="related-pages">
    <span class="related-label">$ related</span>
    <div class="related-list">
      {related.map(p => {
        const href = prefix + p.id.replace(/\/index$/, '') + '/';
        return (
          <a href={href} class="related-page-item">
            <span class="related-tag">{p.data.section.toUpperCase()}</span>
            <span class="related-title">{p.data.title}</span>
          </a>
        );
      })}
    </div>
  </div>
)}

<style>
  .related-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .related-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }
  .related-page-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.35rem 0.6rem;
    color: var(--text-secondary);
    border-left: 2px solid transparent;
    font-size: 0.83rem;
    transition: all 0.15s;
  }
  .related-page-item:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
    border-left-color: var(--accent);
    text-decoration: none;
  }
  .related-tag {
    font-size: 0.65rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    color: var(--accent);
    min-width: 2.5rem;
    text-align: center;
  }
</style>
