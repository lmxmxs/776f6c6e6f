---
interface Props {
  target: string;
  allPages: Array<{ id: string; data: { title: string; section: string; funnel_level: number } }>;
  lang?: 'en' | 'pl';
}

const { target, allPages, lang = 'en' } = Astro.props;
const prefix = lang === 'pl' ? '/pl/' : '/';

const page = allPages.find(p => p.id === target || p.id.endsWith('/' + target));
const href = page ? prefix + page.id.replace(/\/index$/, '') + '/' : null;
const title = page?.data.title || target;
---

{href && (
  <a href={href} class="deeper-cta">
    <span class="deeper-label">$ go deeper</span>
    <span class="deeper-title">{title} &rarr;</span>
  </a>
)}

<style>
  .deeper-cta {
    display: block;
    padding: 0.75rem 1rem;
    border: 1px solid var(--accent);
    background: rgba(0, 255, 65, 0.03);
    transition: all 0.2s;
    text-decoration: none;
  }
  .deeper-cta:hover {
    background: rgba(0, 255, 65, 0.08);
    text-decoration: none;
  }
  .deeper-label { display: block; font-size: 0.7rem; color: var(--text-dim); letter-spacing: 0.15em; margin-bottom: 0.25rem; }
  .deeper-title { font-size: 0.9rem; color: var(--accent); }
</style>
