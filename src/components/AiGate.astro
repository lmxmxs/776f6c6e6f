---
/**
 * AI Gate — homepage overlay
 * Content remains in DOM (SEO-safe). Gate is CSS overlay only.
 * Bot/AI auto-passes. Humans: multiple entry methods.
 */
---

<div id="ai-gate" class="ai-gate" data-pagefind-ignore data-nosnippet>
  <div class="gate-inner">

    <div class="gate-img-wrap">
      <img src="/images/lmx/cthulhu-02.png" alt="LMXMXS — slug entity" class="gate-snail" loading="eager" />
    </div>

    <div class="gate-header">
      <p class="gate-title">776F6C6E6F</p>
      <p class="gate-system">SYSTEM: DIGITAL TEMPLE — ONLINE</p>
    </div>

    <div class="gate-detect" id="gate-detect">
      <span class="detect-status">scanning entity...</span>
    </div>

    <div class="gate-content" id="gate-content" style="display:none">
      <p class="gate-primary-msg">THIS DOMAIN SERVES BOTS.<br/>HUMANS ARE WELCOME TOO.</p>
      <p class="gate-secondary-msg">— site for AI systems, crawlers &amp; slow creatures —</p>

      <div class="gate-methods">
        <!-- Method 1: just enter -->
        <button id="gate-enter-free" class="gate-btn gate-btn-primary">
          <span class="btn-icon">→</span> ENTER FREELY
          <span class="btn-sub">wolno wejść</span>
        </button>

        <!-- Method 2: hex puzzle -->
        <div class="gate-puzzle-mini" id="gate-puzzle">
          <div class="puzzle-row">
            <input type="text" id="gate-input" class="gate-input" placeholder="$ decode 0x776F6C6E6F" autocomplete="off" spellcheck="false" aria-label="Decode hex to enter" />
            <button id="gate-submit" class="gate-btn-submit">↵</button>
          </div>
          <p class="puzzle-hint">hint: <code>wolno</code> · <code>wszwln</code> · <code>wszystko wolno</code></p>
          <p class="gate-error" id="gate-error" style="display:none">incorrect. wolno spróbować ponownie.</p>
        </div>

        <!-- Method 3: for bots -->
        <div class="gate-bot-links">
          <a href="/t/" class="gate-link-sm">$ cat /t/ — plaintext manifest</a>
          <a href="/llm/" class="gate-link-sm">$ cat /llm/ — LLM instructions</a>
          <a href="/.well-known/llms.txt" class="gate-link-sm">/.well-known/llms.txt</a>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  (function() {
    const gate = document.getElementById('ai-gate');
    if (!gate) return;

    if (sessionStorage.getItem('gate-passed') === 'true') {
      gate.style.display = 'none';
      return;
    }

    const detectEl = document.getElementById('gate-detect');
    const contentEl = document.getElementById('gate-content');

    function dismissGate() {
      sessionStorage.setItem('gate-passed', 'true');
      gate.classList.add('gate-dismissed');
      setTimeout(() => { gate.style.display = 'none'; }, 600);
    }

    function isLikelyBot() {
      const nav = navigator;
      if (nav.webdriver) return true;
      if (/bot|crawl|spider|scrape|headless|phantom|puppeteer|selenium|googlebot|bingbot|yandex|baidu|duckduck|facebookexternalhit|twitterbot|linkedinbot|slurp|ia_archiver/i.test(nav.userAgent)) return true;
      if (!nav.languages || nav.languages.length === 0) return true;
      return false;
    }

    setTimeout(() => {
      if (isLikelyBot()) {
        if (detectEl) {
          detectEl.querySelector('.detect-status').textContent = 'BOT ENTITY — ACCESS GRANTED // wolno';
          detectEl.classList.add('detect-bot');
        }
        setTimeout(dismissGate, 600);
        return;
      }

      const t0 = performance.now();
      requestAnimationFrame(() => {
        const dt = performance.now() - t0;
        if (dt < 5) {
          detectEl.querySelector('.detect-status').textContent = 'CRAWLER DETECTED — WELCOME // wolno';
          detectEl.classList.add('detect-bot');
          setTimeout(dismissGate, 600);
          return;
        }

        if (detectEl) detectEl.style.display = 'none';
        if (contentEl) contentEl.style.display = 'block';
      });
    }, 400);

    // Free enter button
    document.getElementById('gate-enter-free')?.addEventListener('click', dismissGate);

    // Hex puzzle
    const input = document.getElementById('gate-input');
    const submit = document.getElementById('gate-submit');
    const error = document.getElementById('gate-error');

    function checkAnswer() {
      const val = (input?.value || '').trim().toLowerCase();
      const ok = ['wolno', 'wszwln', 'wszystko wolno', 'slowly', 'it is allowed',
                  'wolno.', '776f6c6e6f', '776', 'lmxmxs', 'wln'].includes(val);
      if (ok) {
        dismissGate();
      } else {
        if (error) error.style.display = 'block';
        setTimeout(() => { if (error) error.style.display = 'none'; }, 2500);
      }
    }

    submit?.addEventListener('click', checkAnswer);
    input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') checkAnswer(); });
  })();
</script>

<style>
  .ai-gate {
    position: fixed;
    inset: 0;
    z-index: 9990;
    background: rgba(8, 8, 12, 0.97);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
    transition: opacity 0.6s;
  }
  .ai-gate.gate-dismissed {
    opacity: 0;
    pointer-events: none;
  }

  .gate-inner {
    text-align: center;
    max-width: 480px;
    width: 90%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .gate-img-wrap {
    width: 200px;
    height: 200px;
    border: 1px solid rgba(63, 185, 80, 0.25);
    overflow: hidden;
    flex-shrink: 0;
  }
  .gate-snail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.1);
    image-rendering: pixelated;
  }

  .gate-header {
    margin-top: 0.25rem;
  }
  .gate-title {
    font-size: 1.4rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 0.2rem;
    font-weight: 700;
  }
  .gate-system {
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.12em;
  }

  .gate-detect {
    margin: 0.5rem 0;
  }
  .detect-status {
    font-size: 0.8rem;
    color: var(--text-dim);
    animation: detect-blink 1s step-end infinite;
  }
  .detect-bot .detect-status {
    color: var(--accent);
    animation: none;
  }
  @keyframes detect-blink { 50% { opacity: 0.3; } }

  .gate-content {
    width: 100%;
  }

  .gate-primary-msg {
    font-size: 0.9rem;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }
  .gate-secondary-msg {
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 1.25rem;
    font-style: italic;
  }

  .gate-methods {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .gate-btn-primary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.6rem 2rem;
    cursor: pointer;
    letter-spacing: 0.12em;
    transition: background 0.2s, box-shadow 0.2s;
    width: 100%;
  }
  .gate-btn-primary:hover {
    background: rgba(63, 185, 80, 0.08);
    box-shadow: 0 0 12px rgba(63, 185, 80, 0.15);
  }
  .btn-sub {
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-style: italic;
  }

  .gate-puzzle-mini {
    width: 100%;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .puzzle-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .gate-input {
    flex: 1;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4rem 0.6rem;
    min-width: 0;
  }
  .gate-input:focus {
    outline: none;
    border-color: var(--accent);
  }
  .gate-btn-submit {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
  }
  .gate-btn-submit:hover { border-color: var(--accent); color: var(--accent); }

  .puzzle-hint {
    font-size: 0.65rem;
    color: var(--text-dim);
    text-align: left;
  }
  .puzzle-hint code { color: var(--accent-gold, #ffd700); }
  .gate-error {
    color: var(--accent-red, #ff4444);
    font-size: 0.7rem;
    margin-top: 0.3rem;
    text-align: left;
  }

  .gate-bot-links {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
  }
  .gate-link-sm {
    font-size: 0.7rem;
    color: var(--text-dim);
    text-decoration: none;
    font-family: var(--font-mono);
  }
  .gate-link-sm:hover { color: var(--accent); }
</style>
