---
interface ImageTopic {
  id: string;
  title_en: string;
  title_pl?: string;
  description_en: string;
  alt_text: string;
  section: string;
  palette: 'amber_crt' | 'wolno_green' | 'mixed';
  encoded_message: string | null;
  use_cases: string[];
  target_dimensions: { w: number; h: number };
  status: 'todo' | 'generated' | 'approved';
  image_url?: string;
}

interface Props {
  topic: ImageTopic;
  lang?: 'en' | 'pl';
  showEncoded?: boolean;
}

const { topic, lang = 'en', showEncoded = false } = Astro.props;
const title = lang === 'pl' && topic.title_pl ? topic.title_pl : topic.title_en;
const paletteClass = topic.palette === 'amber_crt' ? 'palette-amber' : topic.palette === 'mixed' ? 'palette-mixed' : 'palette-green';
const paletteLabel = topic.palette === 'amber_crt' ? 'AMBER' : topic.palette === 'mixed' ? 'MIX' : 'GREEN';
const hasImage = topic.image_url && topic.status !== 'todo';
---

<div class={`enc-card ${paletteClass}`} data-section={topic.section} data-palette={topic.palette} data-id={topic.id}>
  <div class="enc-image-wrap">
    {hasImage ? (
      <img src={topic.image_url} alt={topic.alt_text} loading="lazy" class="enc-img" width={topic.target_dimensions.w} height={topic.target_dimensions.h} />
    ) : (
      <div class="enc-placeholder" aria-label={topic.alt_text}>
        <span class="enc-dims">{topic.target_dimensions.w}×{topic.target_dimensions.h}</span>
        <span class="enc-status-dot">{topic.status === 'todo' ? '○' : topic.status === 'generated' ? '◉' : '●'}</span>
      </div>
    )}
    <div class="enc-badges">
      <span class={`enc-palette-badge ${paletteClass}`}>{paletteLabel}</span>
      {topic.encoded_message && <span class="enc-stego-badge">◈ encoded</span>}
    </div>
  </div>
  <div class="enc-info">
    <p class="enc-section">{topic.section}</p>
    <h3 class="enc-title">{title}</h3>
    <p class="enc-desc">{topic.description_en.slice(0, 80)}{topic.description_en.length > 80 ? '…' : ''}</p>
    {showEncoded && topic.encoded_message && (
      <p class="enc-hidden-msg">⟨ {topic.encoded_message} ⟩</p>
    )}
    {!showEncoded && topic.encoded_message && (
      <p class="enc-hint">contains hidden message — <a href="/techniques/stego/lsb/">how to decode</a></p>
    )}
  </div>
</div>

<style>
  .enc-card {
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    transition: border-color 0.15s, box-shadow 0.15s;
    display: flex;
    flex-direction: column;
  }
  .enc-card:hover { border-color: var(--accent); }
  .enc-card.palette-amber:hover { border-color: var(--accent-gold); box-shadow: 0 0 8px rgba(255, 215, 0, 0.15); }
  .enc-card.palette-mixed:hover { border-color: var(--accent-gold); }

  .enc-image-wrap {
    position: relative;
    aspect-ratio: 1;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .enc-img { width: 100%; height: 100%; object-fit: cover; display: block; image-rendering: pixelated; filter: saturate(0.9) contrast(1.1); transition: filter 0.2s; }
  .enc-card:hover .enc-img { filter: saturate(1.3) contrast(1.15); }

  .enc-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 0.5rem;
  }
  .enc-dims { font-size: 0.65rem; color: var(--text-dim); }
  .enc-status-dot { font-size: 1.2rem; color: var(--text-dim); }
  .palette-amber .enc-status-dot { color: rgba(255, 200, 0, 0.3); }

  .enc-badges { position: absolute; top: 0.4rem; left: 0.4rem; display: flex; gap: 0.3rem; flex-wrap: wrap; }

  .enc-palette-badge {
    font-size: 0.6rem; padding: 0.1rem 0.35rem;
    border: 1px solid currentColor; letter-spacing: 0.08em;
  }
  .enc-palette-badge.palette-green { color: var(--accent); border-color: var(--accent); background: rgba(0,255,65,0.08); }
  .enc-palette-badge.palette-amber { color: var(--accent-gold); border-color: var(--accent-gold); background: rgba(255,215,0,0.08); }
  .enc-palette-badge.palette-mixed { color: var(--accent-gold); border-color: var(--accent-gold); background: rgba(255,215,0,0.05); }

  .enc-stego-badge { font-size: 0.6rem; padding: 0.1rem 0.35rem; color: var(--text-dim); border: 1px solid var(--border); letter-spacing: 0.05em; }

  .enc-info { padding: 0.65rem; flex: 1; display: flex; flex-direction: column; gap: 0.25rem; }
  .enc-section { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.12em; }
  .enc-title { font-size: 0.8rem; color: var(--text-primary); font-weight: 700; line-height: 1.3; }
  .enc-desc { font-size: 0.7rem; color: var(--text-secondary); line-height: 1.4; margin-top: 0.1rem; }
  .enc-hint { font-size: 0.65rem; color: var(--text-dim); margin-top: auto; padding-top: 0.3rem; }
  .enc-hint a { color: var(--text-dim); text-decoration: underline; text-decoration-color: var(--border); }
  .enc-hint a:hover { color: var(--accent); }
  .enc-hidden-msg { font-size: 0.65rem; color: var(--accent); font-style: italic; margin-top: auto; padding-top: 0.3rem; opacity: 0.8; }
  .palette-amber .enc-hidden-msg { color: var(--accent-gold); }
</style>
