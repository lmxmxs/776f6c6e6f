---
/**
 * HeroSection - Uniwersalny komponent sekcji Hero
 *
 * Wzorowany na Barnabaai Hero.astro
 *
 * @param {string} title - Główny tytuł
 * @param {string} subtitle - Podtytuł
 * @param {string} description - Opis (opcjonalny)
 * @param {string} buttonText - Tekst przycisku CTA
 * @param {string} buttonHref - Link przycisku CTA
 * @param {string} imageSrc - Ścieżka do obrazu w CircularImage
 * @param {string} imageAlt - Alt text obrazu
 * @param {string} imageColor - Kolor obramowania obrazu
 * @param {string} size - Rozmiar CircularImage (sm, md, lg, xl)
 * @param {boolean} pulse - Czy obraz ma pulsować
 * @param {boolean} reverseLayout - Odwróć układ (obraz po prawej)
 * @param {string} class - Dodatkowe klasy CSS
 */

import CircularImage from '../../circular-image/components/CircularImage.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  imageSrc?: string;
  imageAlt?: string;
  imageColor?: string;
  imageSize?: 'sm' | 'md' | 'lg' | 'xl';
  pulse?: boolean;
  reverseLayout?: boolean;
  class?: string;
}

const {
  title,
  subtitle,
  description,
  buttonText = 'Dowiedz się więcej',
  buttonHref = '#',
  imageSrc,
  imageAlt = '',
  imageColor = '#3B82F6',
  imageSize = 'xl',
  pulse = false,
  reverseLayout = false,
  class: cssClass = '',
} = Astro.props;
---

<section class={`hero-section ${cssClass}`}>
  <div class={`hero-container ${reverseLayout ? 'reverse' : ''}`}>
    <!-- Obrazek CircularImage -->
    {imageSrc && (
      <div class="hero-image">
        <CircularImage
          src={imageSrc}
          alt={imageAlt}
          size={imageSize}
          borderColor={imageColor}
          borderWidth={3}
          glow={true}
          pulse={pulse}
          type="interactive"
        />
      </div>
    )}

    <!-- Treść tekstowa -->
    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>

      {subtitle && (
        <h2 class="hero-subtitle">{subtitle}</h2>
      )}

      {description && (
        <p class="hero-description">{description}</p>
      )}

      {buttonText && buttonHref && (
        <div class="hero-button-container">
          <a href={buttonHref} class="hero-button">
            {buttonText}
            <svg class="button-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      )}

      <!-- Slot dla dodatkowych elementów -->
      <slot />
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    padding: 4rem 1rem;
    margin: 0 auto;
    max-width: 1280px;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .hero-container {
      flex-direction: row;
      gap: 4rem;
      align-items: center;
    }

    .hero-container.reverse {
      flex-direction: row-reverse;
    }
  }

  .hero-image {
    flex-shrink: 0;
  }

  .hero-content {
    flex: 1;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      text-align: left;
    }

    .hero-container.reverse .hero-content {
      text-align: right;
    }
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--primary-400, #3B82F6), var(--primary-600, #2563EB));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: 3.5rem;
    }
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-primary, #1F2937);
  }

  .dark .hero-subtitle {
    color: var(--text-primary-dark, #F9FAFB);
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: 2rem;
    }
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.75;
    margin-bottom: 2rem;
    color: var(--text-secondary, #4B5563);
  }

  .dark .hero-description {
    color: var(--text-secondary-dark, #D1D5DB);
  }

  .hero-button-container {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .hero-button-container {
      justify-content: flex-start;
    }

    .hero-container.reverse .hero-button-container {
      justify-content: flex-end;
    }
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, var(--primary-400, #3B82F6), var(--primary-600, #2563EB));
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px 0 rgba(59, 130, 246, 0.39);
  }

  .hero-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px 0 rgba(59, 130, 246, 0.5);
  }

  .hero-button:active {
    transform: translateY(0);
  }

  .button-icon {
    width: 1.25rem;
    height: 1.25rem;
    transition: transform 0.3s ease;
  }

  .hero-button:hover .button-icon {
    transform: translateX(4px);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .hero-section {
      padding: 2rem 1rem;
    }

    .hero-container {
      gap: 2rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1.25rem;
    }

    .hero-description {
      font-size: 1rem;
    }
  }
</style>
