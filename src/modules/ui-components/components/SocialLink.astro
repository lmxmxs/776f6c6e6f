---
/**
 * SocialLink — multi-variant social link component
 * variant: "card" (links page) | "footer-inline" (footer) | "hero-mini" (homepage grid)
 */
import type { SocialLinkData } from '../../../data/social-links';

interface Props {
  link: SocialLinkData;
  variant?: 'card' | 'footer-inline' | 'hero-mini';
}

const { link, variant = 'card' } = Astro.props;

const target = link.url.startsWith('/') ? '_self' : '_blank';
const relParts = ['noopener'];
if (link.rel) relParts.unshift(link.rel);
const rel = relParts.join(' ');
---

{variant === 'card' && (
  <a href={link.url} class="sl-card" target={target} rel={rel}>
    <span class="sl-icon">{link.icon}</span>
    <div class="sl-info">
      <span class="sl-label">{link.label}</span>
      <span class="sl-desc">{link.description}</span>
      <span class="sl-handle">{link.handle}</span>
    </div>
  </a>
)}

{variant === 'footer-inline' && (
  <a href={link.url} class="sl-footer" target={target} rel={rel}>
    <span class="sl-fi-icon">{link.icon}</span><span class="sl-fi-label">{link.label}</span>
  </a>
)}

{variant === 'hero-mini' && (
  <a href={link.url} class="sl-hero" target={target} rel={rel}>
    <span class="sl-hm-icon">{link.icon}</span>
    <span class="sl-hm-label">{link.label}</span>
  </a>
)}

<style>
  /* card variant */
  .sl-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .sl-card:hover {
    border-color: var(--accent);
    background: rgba(0, 255, 65, 0.05);
    text-decoration: none;
  }
  .sl-icon {
    font-size: 1.2rem;
    color: var(--accent);
    min-width: 2rem;
    text-align: center;
  }
  .sl-info { display: flex; flex-direction: column; }
  .sl-label { font-size: 0.9rem; color: var(--text-primary); font-weight: 700; }
  .sl-desc { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.1rem; }
  .sl-handle { font-size: 0.7rem; color: var(--text-dim); opacity: 0.7; margin-top: 0.05rem; }

  /* footer-inline variant */
  .sl-footer {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .sl-footer:hover { opacity: 1; text-decoration: none; }
  .sl-fi-icon { color: var(--accent); font-size: 0.9rem; }
  .sl-fi-label { color: var(--text-primary); }

  /* hero-mini variant */
  .sl-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.75rem 0.5rem;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .sl-hero:hover {
    border-color: var(--accent);
    background: rgba(0, 255, 65, 0.04);
    text-decoration: none;
  }
  .sl-hm-icon { font-size: 1.1rem; color: var(--accent); }
  .sl-hm-label { font-size: 0.75rem; color: var(--text-secondary); }
</style>
