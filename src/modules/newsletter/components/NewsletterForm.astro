---
// Reusable Newsletter Module - WWW v2.0 Standard
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  successMessage?: string;
}

const {
  title = "Zapisz się do newslettera",
  description = "Otrzymuj najnowsze artykuły i oferty biznesowe prosto na swoją skrzynkę!",
  buttonText = "Zapisz się",
  successMessage = "Dziękujemy! Sprawdź swoją skrzynkę email."
} = Astro.props;
---

<div class="bg-primary-50 dark:bg-primary-900/20 rounded-lg p-8">
  <div class="max-w-2xl mx-auto">
    <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2 text-center">
      {title}
    </h3>
    <p class="text-gray-600 dark:text-gray-400 mb-6 text-center">
      {description}
    </p>

    <form id="newsletter-form" class="flex flex-col sm:flex-row gap-4" data-success={successMessage}>
      <input
        type="email"
        name="email"
        placeholder="Twój adres email"
        required
        class="flex-1 px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-400"
      />
      <button
        type="submit"
        class="px-6 py-3 bg-primary-400 hover:bg-primary-500 text-white font-bold rounded-lg transition-colors whitespace-nowrap"
      >
        {buttonText}
      </button>
    </form>

    <!-- Success message (hidden initially) -->
    <div id="newsletter-success" class="hidden mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg text-green-800 dark:text-green-200 text-center">
      {successMessage}
    </div>

    <!-- Error message (hidden initially) -->
    <div id="newsletter-error" class="hidden mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-red-800 dark:text-red-200 text-center">
      Wystąpił błąd. Spróbuj ponownie później.
    </div>

    <p class="text-xs text-gray-500 dark:text-gray-400 mt-4 text-center">
      Nie wysyłamy spamu. Możesz wypisać się w każdej chwili.
    </p>
  </div>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const success = document.getElementById('newsletter-success');
  const error = document.getElementById('newsletter-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get('email');

    try {
      const response = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      if (response.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');

        // Hide success message after 5s
        setTimeout(() => {
          success?.classList.add('hidden');
        }, 5000);
      } else {
        throw new Error('Subscription failed');
      }
    } catch (err) {
      error?.classList.remove('hidden');
      success?.classList.add('hidden');

      // Hide error message after 5s
      setTimeout(() => {
        error?.classList.add('hidden');
      }, 5000);
    }
  });
</script>
