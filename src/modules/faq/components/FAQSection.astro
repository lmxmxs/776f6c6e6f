---
/**
 * FAQSection - Uniwersalny komponent sekcji FAQ (Często Zadawane Pytania)
 *
 * @param {string} title - Tytuł sekcji (domyślnie "Często zadawane pytania")
 * @param {string} subtitle - Podtytuł (opcjonalny)
 * @param {Array} items - Tablica pytań i odpowiedzi [{question: string, answer: string}]
 * @param {string} class - Dodatkowe klasy CSS
 */

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  items: FAQItem[];
  class?: string;
}

const {
  title = 'Często zadawane pytania',
  subtitle,
  items = [],
  class: cssClass = '',
} = Astro.props;
---

<section class={`faq-section ${cssClass}`}>
  <div class="faq-container">
    <!-- Header -->
    <div class="faq-header">
      <h2 class="faq-title">{title}</h2>
      {subtitle && <p class="faq-subtitle">{subtitle}</p>}
    </div>

    <!-- FAQ Items -->
    <div class="faq-items">
      {items.map((item, index) => (
        <div class="faq-item" data-faq-item>
          <button
            class="faq-question"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
            data-faq-button
          >
            <span class="question-text">{item.question}</span>
            <svg
              class="faq-icon"
              data-faq-icon
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </button>

          <div
            class="faq-answer"
            id={`faq-answer-${index}`}
            data-faq-answer
          >
            <div class="faq-answer-content" set:html={item.answer} />
          </div>
        </div>
      ))}
    </div>

    <!-- Slot dla dodatkowych elementów -->
    <slot />
  </div>
</section>

<style>
  .faq-section {
    width: 100%;
    padding: 4rem 1rem;
    margin: 0 auto;
  }

  .faq-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .faq-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text-primary, #1F2937);
  }

  .dark .faq-title {
    color: var(--text-primary-dark, #F9FAFB);
  }

  .faq-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary, #6B7280);
  }

  .dark .faq-subtitle {
    color: var(--text-secondary-dark, #D1D5DB);
  }

  .faq-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    border: 1px solid var(--border-color, #E5E7EB);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: all 0.3s ease;
    background: white;
  }

  .dark .faq-item {
    border-color: var(--border-dark, #374151);
    background: var(--bg-secondary-dark, #1F2937);
  }

  .faq-item:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .dark .faq-item:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
  }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.2s ease;
  }

  .faq-question:hover {
    background: rgba(59, 130, 246, 0.05);
  }

  .dark .faq-question:hover {
    background: rgba(59, 130, 246, 0.1);
  }

  .question-text {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary, #1F2937);
  }

  .dark .question-text {
    color: var(--text-primary-dark, #F9FAFB);
  }

  .faq-icon {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--primary-400, #3B82F6);
    transition: transform 0.3s ease;
  }

  .faq-item[data-expanded="true"] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq-answer-content {
    padding: 0 1.5rem 1.25rem 1.5rem;
    color: var(--text-secondary, #6B7280);
    line-height: 1.75;
  }

  .dark .faq-answer-content {
    color: var(--text-secondary-dark, #D1D5DB);
  }

  .faq-answer-content :global(p) {
    margin-bottom: 0.75rem;
  }

  .faq-answer-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .faq-answer-content :global(a) {
    color: var(--primary-400, #3B82F6);
    text-decoration: underline;
  }

  .faq-answer-content :global(a:hover) {
    color: var(--primary-600, #2563EB);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .faq-section {
      padding: 2rem 1rem;
    }

    .faq-title {
      font-size: 2rem;
    }

    .question-text {
      font-size: 1rem;
    }

    .faq-question {
      padding: 1rem;
    }

    .faq-answer-content {
      padding: 0 1rem 1rem 1rem;
    }
  }
</style>

<script>
  function initFAQ() {
    const faqItems = document.querySelectorAll('[data-faq-item]');

    faqItems.forEach((item) => {
      const button = item.querySelector('[data-faq-button]') as HTMLButtonElement;
      const answer = item.querySelector('[data-faq-answer]') as HTMLElement;

      if (!button || !answer) return;

      button.addEventListener('click', () => {
        const isExpanded = item.getAttribute('data-expanded') === 'true';

        if (isExpanded) {
          // Collapse
          item.setAttribute('data-expanded', 'false');
          button.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = '0';
        } else {
          // Expand
          item.setAttribute('data-expanded', 'true');
          button.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initFAQ);
  document.addEventListener('astro:page-load', initFAQ);

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    setTimeout(initFAQ, 100);
  }
</script>
