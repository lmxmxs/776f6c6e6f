  "settings": {
    "sessionMaxAge": {
      "type": "number",
      "label": "Czas sesji (godziny)",
      "default": 24,
      "description": "Jak długo sesja jest aktywna"
    },
    "rememberMeDays": {
      "type": "number",
      "label": "Zapamiętaj mnie (dni)",
      "default": 30,
      "description": "Czas ważności cookie przy 'Zapamiętaj mnie'"
    }
  },
  "exports": {
    "components": [
      "components/ArticleEditor.astro",
      "components/ImageEditor.astro"
    ],
    "utils": [
      "lib/articles.ts",
      "lib/auth.ts"
    ]
  },
  "config": {
    "required": [],
    "optional": [
      "SESSION_SECRET",
      "SESSION_MAX_AGE"
    ]
  },
  "tags": [
    "admin",
    "auth",
    "cms",
    "feature",
    "core"
  ],
  "features": [
    "Autentykacja SQLite",
    "Zarządzanie artykułami",
    "Edycja obrazków",
    "Dashboard z statystykami",
    "Media library"
  ]
}
