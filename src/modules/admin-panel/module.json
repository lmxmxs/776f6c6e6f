{
  "id": "admin-panel",
  "name": "Admin Panel",
  "version": "2.0.0",
  "description": "Kompletny panel administracyjny z autentykacją, zarządzaniem artykułami i mediami",
  "author": "Barnabaai",
  "license": "MIT",
  "enabled": true,
  "icon": "shield-check",
  "compatibility": {
    "astro": "^5.0.0",
    "www_standard": "2.0.x"
  },
  "dependencies": {
    "react": "^19.0.0",
    "astro": "^5.0.0"
  },
  "adminPages": [
    {
