---
// @PATH: /src/components/admin/ArticleEditor.astro
// @PROJECT: 112358 (Fraktale Galeria)
// Article edit button - shows for authenticated users

import { isAuthenticated } from '../../lib/admin/auth';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const authenticated = isAuthenticated(Astro.cookies);
---

{authenticated && (
  <div class="article-editor-wrapper">
    <a
      href={`/admin/articles?edit=${slug}`}
      class="edit-article-btn"
      title="Edytuj artykuł"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
      </svg>
      <span>Edytuj artykuł</span>
    </a>
  </div>
)}

<style>
  .article-editor-wrapper {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
  }

  .edit-article-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background-color: var(--accent-primary);
    color: white;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }

  .edit-article-btn:hover {
    background-color: var(--accent-secondary);
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
  }

  .edit-article-btn svg {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .article-editor-wrapper {
      bottom: 1rem;
      right: 1rem;
    }

    .edit-article-btn span {
      display: none;
    }

    .edit-article-btn {
      padding: 0.75rem;
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      justify-content: center;
    }
  }
</style>
