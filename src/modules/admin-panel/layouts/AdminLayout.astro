---
/**
 * AdminLayout
 * Universal layout for admin panel pages
 *
 * Features:
 * - Session verification
 * - Dynamic sidebar navigation from modules
 * - User info display
 * - Logout functionality
 * - Role-based menu items
 *
 * @PATH: /src/modules/admin-panel/layouts/AdminLayout.astro
 * @PROJECT: barnabaai
 */

import { getUserBySession } from '../utils/auth';
import { getGroupedAdminPages, type AdminPage } from '../../../lib/modules/loader';
import type { User } from '../types';

interface Props {
  title: string;
  description?: string;
  requiredRole?: 'admin' | 'moderator' | 'user';
}

const { title, description, requiredRole } = Astro.props;

// Get user from session (auth check should be done at page level)
const sessionToken = Astro.cookies.get('session_token')?.value;
const user: User | null = sessionToken ? getUserBySession(sessionToken) : null;

// Fallback user for layout rendering (page should have already redirected if no auth)
const displayUser = user || { username: 'Guest', role: 'user' as const };

// Role display names
const roleNames: Record<string, string> = {
  'admin': 'Administrator',
  'moderator': 'Moderator',
  'editor': 'Redaktor',
  'user': 'Użytkownik'
};

// Get dynamic navigation from modules
const { main: navItems, subpages } = getGroupedAdminPages(displayUser.role);

// Page title
const pageTitle = `${title} | Panel Administracyjny`;

// Check if current path is active or its children are active
function isActive(page: AdminPage): boolean {
  const currentPath = Astro.url.pathname;
  if (currentPath === page.path) return true;
  // Check if any subpage is active
  const pageSubpages = subpages[page.path] || [];
  return pageSubpages.some(sub => currentPath === sub.path);
}
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}

    <!-- Prevent indexing of admin pages -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Theme initialization -->
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col">
        <!-- Logo / Header -->
        <div class="p-6 border-b border-gray-200 dark:border-gray-700">
          <a href="/" class="flex items-center gap-3 group">
            <div class="w-10 h-10 bg-primary-400 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-sm">Panel Admina</div>
              <div class="text-xs text-gray-500 dark:text-gray-400 group-hover:text-primary-400">← Powrót na stronę</div>
            </div>
          </a>
        </div>

        <!-- User info -->
        <div class="p-4 border-b border-gray-200 dark:border-gray-700">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-medium text-sm truncate">{displayUser.username}</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">{roleNames[displayUser.role] || displayUser.role}</div>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 overflow-y-auto">
          <ul class="space-y-1">
            {navItems.map(item => {
              const itemSubpages = subpages[item.path] || [];
              const hasSubpages = itemSubpages.length > 0;
              const active = isActive(item);

              return (
                <li>
                  <a
                    href={item.path}
                    class:list={[
                      "flex items-center gap-3 px-4 py-3 rounded-lg transition group",
                      active
                        ? "bg-primary-50 dark:bg-primary-900/20 text-primary-400"
                        : "hover:bg-gray-100 dark:hover:bg-gray-700"
                    ]}
                  >
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                    </svg>
                    <span class="font-medium text-sm">{item.label}</span>
                    {hasSubpages && (
                      <svg class:list={["w-4 h-4 ml-auto transition-transform", active && "rotate-90"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    )}
                  </a>
                  {/* Subpages */}
                  {hasSubpages && active && (
                    <ul class="ml-6 mt-1 space-y-1 border-l-2 border-gray-200 dark:border-gray-700 pl-4">
                      {itemSubpages.map(subpage => (
                        <li>
                          <a
                            href={subpage.path}
                            class:list={[
                              "flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition",
                              Astro.url.pathname === subpage.path
                                ? "bg-primary-50 dark:bg-primary-900/20 text-primary-400"
                                : "text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-gray-100"
                            ]}
                          >
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={subpage.icon} />
                            </svg>
                            <span>{subpage.label}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </nav>

        <!-- Logout button -->
        <div class="p-4 border-t border-gray-200 dark:border-gray-700">
          <button
            id="logout-button"
            class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30 transition font-medium text-sm"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Wyloguj się
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 overflow-y-auto">
        <!-- Top bar -->
        <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-8 py-4">
          <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold">{title}</h1>
            <div class="flex items-center gap-4">
              <div class="text-sm text-gray-500 dark:text-gray-400">
                {new Date().toLocaleDateString('pl-PL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
              </div>
            </div>
          </div>
          {description && (
            <p class="text-gray-600 dark:text-gray-400 mt-2">{description}</p>
          )}
        </header>

        <!-- Page content -->
        <div class="p-8">
          <!-- Error/success messages -->
          {Astro.url.searchParams.get('error') && (
            <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-800 dark:text-red-200 rounded-lg">
              ✗ {Astro.url.searchParams.get('error')}
            </div>
          )}
          {Astro.url.searchParams.get('success') && (
            <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-200 rounded-lg">
              ✓ {Astro.url.searchParams.get('success')}
            </div>
          )}

          <slot />
        </div>
      </main>
    </div>

    <!-- Logout functionality -->
    <script>
      const logoutButton = document.getElementById('logout-button');

      logoutButton?.addEventListener('click', async () => {
        try {
          const response = await fetch('/api/auth/logout', {
            method: 'POST'
          });

          if (response.ok) {
            window.location.href = '/admin?success=Wylogowano pomyślnie';
          } else {
            alert('Błąd podczas wylogowywania');
          }
        } catch (error) {
          console.error('Logout error:', error);
          alert('Błąd podczas wylogowywania');
        }
      });
    </script>
  </body>
</html>
