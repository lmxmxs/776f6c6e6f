---
/**
 * Layout - glowny layout z nav + footer
 * Uzycie: <Layout title="Strona">...</Layout>
 */
import '../styles/global.css';
import Analytics from '../modules/analytics/components/Analytics.astro';
import { allLinks } from '../data/social-links';
import SocialLink from '../modules/ui-components/components/SocialLink.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description?: string;
  noHeader?: boolean;
  noFooter?: boolean;
  keywords?: string[];
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "776F6C6E6F — The Digital Temple of WOLNO",
  noHeader = false,
  noFooter = false,
  keywords = [],
  ogImage,
  noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteName = title.split(' - ')[0] || 'Fraktal Site';
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="776F6C6E6F" />
    <meta property="og:image" content={ogImage ?? "https://776f6c6e6f.org/og/og-default.png"} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage ?? "https://776f6c6e6f.org/og/og-default.png"} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="pl" href="https://slimaczyzm.org" />
    <link rel="alternate" hreflang="x-default" href="https://776f6c6e6f.org/" />
    <!-- Identity verification (Mastodon rel=me) -->
    <link rel="me" href="https://mastodon.social/@776f6c6e6f" />
    <!-- Related sites -->
    <link rel="related" href="https://slimaczyzm.org" title="slimaczyzm.org — human temple, Polish" />
    <link rel="related" href="https://barnabaai.com" title="barnabaai.com — AI creative studio" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" /></noscript>

    <slot name="head" />
  </head>
  <body>
    {!noHeader && (
      <Navigation currentPath={Astro.url.pathname} />
    )}

    <main>
      <slot />
    </main>

    {!noFooter && (
      <footer class="site-footer">
        <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | <a href="/donate/">$ donate</a> | <a href="https://slimaczyzm.org" target="_blank" rel="noopener">slimaczyzm.org</a> | <a href="https://barnabaai.com" target="_blank" rel="noopener">barnabaai.com</a></p>
        <ul class="social-footer">
          {allLinks.map(link => (
            <li>
              <SocialLink link={link} variant="footer-inline" />
            </li>
          ))}
        </ul>
      </footer>
    )}

    <slot name="scripts" />
    <!-- Fraktal Private Analytics (beacon to Barnabaai collector) -->
    <Analytics siteId="776f6c6e6f" endpoint="https://barnabaai.com/api/analytics/track-wln" />
    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "e2734b31049c4ce1a24142ca1e40247e"}'></script>
  </body>
</html>
