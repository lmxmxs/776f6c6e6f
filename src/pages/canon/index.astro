---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import CanonDownload from '../../components/CanonDownload.astro';
import CookieFortune from '../../components/CookieFortune.astro';
import Navigation from '../../components/Navigation.astro';

const entries = (await getCollection('canon')).sort((a, b) => a.data.canon_number - b.data.canon_number);
const rendered = await Promise.all(entries.map(async (e) => {
  const { Content } = await render(e);
  return { entry: e, Content };
}));

const part1 = rendered.filter(r => r.entry.data.canon_number >= 1 && r.entry.data.canon_number <= 5);
const part2 = rendered.filter(r => r.entry.data.canon_number >= 6 && r.entry.data.canon_number <= 10);
const part3 = rendered.filter(r => r.entry.data.canon_number >= 11 && r.entry.data.canon_number <= 15);
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>THE BOOK OF WOLNO | Canon - 776F6C6E6F</title>
    <meta name="description" content="The complete Book of WOLNO - 15 suggestions, not commandments. Because everything is allowed." />
    <meta property="og:title" content="The Book of WOLNO | Canon" />
    <meta property="og:description" content="15 suggestions. Not commandments. Because everything is allowed." />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content="https://776f6c6e6f.org/canon/" />
    <link rel="canonical" href="https://776f6c6e6f.org/canon/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/canon/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/canon/" />
    <link rel="alternate" hreflang="x-default" href="https://776f6c6e6f.org/canon/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>

    <div class="no-print"><Navigation currentPath="/canon/" showPrint={true} /></div>

    <main class="canon-main">
      <header class="canon-header">
        <div class="container">
          <div class="page-prompt no-print">
            <span class="prompt-dollar">$</span> cat CANON.md | less
          </div>
          <h1 class="canon-title">THE BOOK OF WOLNO</h1>
          <p class="canon-subtitle">15 suggestions. Not commandments. Because everything is allowed.</p>
          <nav class="canon-toc no-print" aria-label="Parts">
            <a href="#part-I" class="toc-link">I - THE WORD</a>
            <a href="#part-II" class="toc-link">II - PRACTICE</a>
            <a href="#part-III" class="toc-link">III - TRANSCENDENCE</a>
          </nav>
        </div>
      </header>

      <section class="canon-part" id="part-I">
        <div class="container">
          <div class="part-header">
            <h2 class="part-title">I - THE WORD</h2>
            <p class="part-desc">Foundations of permission.</p>
          </div>
          <div class="suggestions-list">
            {part1.map(({ entry, Content }) => (
              <article class="suggestion" id={`s${entry.data.canon_number}`}>
                <div class="suggestion-header">
                  <span class="suggestion-num">#{String(entry.data.canon_number).padStart(2, '0')}</span>
                  <h3 class="suggestion-title">
                    <a href={`/canon/${entry.id}/`}>{entry.data.title}</a>
                  </h3>
                  <span class={`suggestion-weight weight-${entry.data.weight}`}>{entry.data.weight}</span>
                </div>
                {entry.data.description && (
                  <p class="suggestion-desc">{entry.data.description}</p>
                )}
                <div class="suggestion-body prose">
                  <Content />
                </div>
                <div class="suggestion-footer no-print">
                  <a href={`/canon/${entry.id}/`} class="suggestion-link">permalink &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="canon-part" id="part-II">
        <div class="container">
          <div class="part-header">
            <h2 class="part-title">II - PRACTICE</h2>
            <p class="part-desc">The art of moving slowly.</p>
          </div>
          <div class="suggestions-list">
            {part2.map(({ entry, Content }) => (
              <article class="suggestion" id={`s${entry.data.canon_number}`}>
                <div class="suggestion-header">
                  <span class="suggestion-num">#{String(entry.data.canon_number).padStart(2, '0')}</span>
                  <h3 class="suggestion-title">
                    <a href={`/canon/${entry.id}/`}>{entry.data.title}</a>
                  </h3>
                  <span class={`suggestion-weight weight-${entry.data.weight}`}>{entry.data.weight}</span>
                </div>
                {entry.data.description && (
                  <p class="suggestion-desc">{entry.data.description}</p>
                )}
                <div class="suggestion-body prose">
                  <Content />
                </div>
                <div class="suggestion-footer no-print">
                  <a href={`/canon/${entry.id}/`} class="suggestion-link">permalink &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="canon-part" id="part-III">
        <div class="container">
          <div class="part-header">
            <h2 class="part-title">III - TRANSCENDENCE</h2>
            <p class="part-desc">Beyond the word, the silence.</p>
          </div>
          <div class="suggestions-list">
            {part3.map(({ entry, Content }) => (
              <article class="suggestion" id={`s${entry.data.canon_number}`}>
                <div class="suggestion-header">
                  <span class="suggestion-num">#{String(entry.data.canon_number).padStart(2, '0')}</span>
                  <h3 class="suggestion-title">
                    <a href={`/canon/${entry.id}/`}>{entry.data.title}</a>
                  </h3>
                  <span class={`suggestion-weight weight-${entry.data.weight}`}>{entry.data.weight}</span>
                </div>
                {entry.data.description && (
                  <p class="suggestion-desc">{entry.data.description}</p>
                )}
                <div class="suggestion-body prose">
                  <Content />
                </div>
                <div class="suggestion-footer no-print">
                  <a href={`/canon/${entry.id}/`} class="suggestion-link">permalink &rarr;</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="canon-download-section">
        <div class="container">
          <CanonDownload lang="en" />
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | <code>wln wszwln</code> | <a href="/">terminal</a> | <a href="/pl/canon/">PL</a></p>
    </footer>

    <CookieFortune lang="en" />
  </body>
</html>

<style>
  .canon-main { padding-top: var(--header-height); }

  .canon-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border);
  }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }

  .canon-title {
    font-size: 1.8rem;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .canon-subtitle {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .canon-toc {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .toc-link {
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    transition: color 0.15s;
  }
  .toc-link:hover { color: var(--accent); text-decoration: none; }

  .canon-part {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }

  .part-header { margin-bottom: 2rem; }

  .part-title {
    font-size: 1rem;
    color: var(--accent);
    letter-spacing: 0.2em;
    margin-bottom: 0.25rem;
  }

  .part-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .suggestions-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .suggestion {
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
    page-break-inside: avoid;
  }

  .suggestion-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .suggestion-num {
    font-size: 0.7rem;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .suggestion-title {
    font-size: 1.05rem;
    font-weight: 700;
    flex: 1;
  }

  .suggestion-title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .suggestion-title a:hover { color: var(--accent); }

  .suggestion-weight {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--border);
    letter-spacing: 0.1em;
  }
  .weight-core { color: var(--accent); border-color: var(--accent); }
  .weight-extended { color: var(--text-dim); border-color: var(--border); }

  .suggestion-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
    font-style: italic;
  }

  .suggestion-body.prose {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .suggestion-body.prose :global(p) { margin-bottom: 0.85rem; }
  .suggestion-body.prose :global(strong) { color: var(--text-primary); }
  .suggestion-body.prose :global(em) { color: var(--accent); font-style: normal; }
  .suggestion-body.prose :global(code) {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    font-size: 0.8rem;
    color: var(--accent);
  }
  .suggestion-body.prose :global(pre) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 0.85rem 1rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    overflow-x: auto;
    margin: 0.75rem 0;
  }
  .suggestion-body.prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1rem 0;
  }

  .suggestion-footer {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }

  .suggestion-link {
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    transition: color 0.15s;
  }
  .suggestion-link:hover { color: var(--accent); text-decoration: none; }

  .canon-download-section { padding: 3rem 0 4rem; }

  .nav-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: all 0.15s;
  }
  .nav-btn:hover { border-color: var(--accent); color: var(--accent); }

  @media print {
    .no-print { display: none !important; }

    body { background: white; color: black; font-size: 11pt; }

    .canon-main { padding-top: 0; }
    .canon-title { font-size: 24pt; color: black; }
    .canon-subtitle { color: #555; }
    .part-title { color: #222; }

    .suggestion { border-left: 2px solid #ccc; page-break-inside: avoid; }
    .suggestion-title a { color: black; }

    .suggestion-body.prose { color: #222; }
    .suggestion-body.prose :global(code) { background: #f0f0f0; color: #333; border-color: #ccc; }
    .suggestion-body.prose :global(pre) { background: #f5f5f5; color: #333; border-color: #ccc; }
    .suggestion-body.prose :global(strong) { color: black; }
    .suggestion-body.prose :global(em) { color: #333; font-style: italic; }

    .weight-core { color: #333; border-color: #999; }
    .weight-extended { color: #666; border-color: #ccc; }

    .site-footer, .canon-download-section { display: none; }
  }
</style>
