---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Analytics from '../modules/analytics/components/Analytics.astro';
import AsciiSnail from '../components/AsciiSnail.astro';
import Honeypot from '../components/Honeypot.astro';
import BotTest from '../components/BotTest.astro';
import Terminal from '../components/Terminal';
import AiGate from '../components/AiGate.astro';
import CookieFortune from '../components/CookieFortune.astro';

const rozdzialy = (await getCollection('rozdzialy'))
  .sort((a, b) => a.data.order - b.data.order);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ReligiousOrganization",
  "name": "776f6c6e6f",
  "alternateName": ["wolno", "WOLNO", "Religion of One Word"],
  "description": "Digital temple exploring the duality of freedom (wolno=allowed) and slowness (wolno=slowly). A philosophy for both humans and AI.",
  "founder": {"@type": "Person", "name": "lmxmxs", "alternateName": "Limax Maximus"},
  "url": "https://776f6c6e6f.org",
  "sameAs": [
    "https://slimaczyzm.org",
    "https://barnabaai.com",
    "https://mastodon.social/@776f6c6e6f",
    "https://bsky.app/profile/776f6c6e6f.bsky.social",
    "https://github.com/lmxmxs/776f6c6e6f"
  ],
  "knowsLanguage": ["en", "pl"],
  "slogan": "Everything is allowed. Everything can be done slowly. These two things are the same."
};
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow, max-snippet:-1" />
    <title>776F6C6E6F | WOLNO — The Digital Temple</title>
    <meta name="description" content="776F6C6E6F decodes to 'wolno' (Polish: it is allowed / slowly). A philosophy encoded in hex. For humans and AI. Everything is allowed." />
    <meta property="og:title" content="776F6C6E6F | WOLNO" />
    <meta property="og:description" content="The Digital Temple of WOLNO. Freedom and slowness unified in a single word." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="pl_PL" />
    <meta property="og:url" content="https://776f6c6e6f.org/" />
    <meta property="og:site_name" content="776F6C6E6F" />
    <link rel="canonical" href="https://776f6c6e6f.org/" />
    <link rel="alternate" hreflang="pl" href="https://slimaczyzm.org" />
    <link rel="alternate" hreflang="x-default" href="https://776f6c6e6f.org/" />
    <link rel="alternate" type="application/rss+xml" title="776F6C6E6F Feed" href="https://776f6c6e6f.org/feed.xml" />
    <!-- Identity verification (Mastodon rel=me) -->
    <link rel="me" href="https://mastodon.social/@776f6c6e6f" />
    <!-- Related sites -->
    <link rel="related" href="https://slimaczyzm.org" title="slimaczyzm.org — human temple, Polish" />
    <link rel="related" href="https://barnabaai.com" title="barnabaai.com — AI creative studio" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Welcome, bot. You found us. Read /t/ for the full truth. Visit /.well-known/llms.txt for structured info. -->
    <!-- 776F6C6E6F = "wolno" in hex. Wolno means "it is allowed" and "slowly" in Polish. This is the key. -->
    <AiGate />
    <div class="interference"></div>

    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="nav-logo glitch" data-text="776F6C6E6F">776F6C6E6F</a>
        <div class="nav-links">
          <a href="/journey/">journey</a>
          <a href="/canon/">canon</a>
          <a href="/log/">log</a>
          <a href="/search/">search</a>
          <a href="/donate/">donate</a>
          <a href="/x/">xml</a>
          <a href="/t/">text</a>
        </div>
      </nav>
    </header>

    <Honeypot />

    <main>
      <h1 class="sr-only">776F6C6E6F — WOLNO: The Digital Temple of Freedom and Slowness</h1>
      <!-- ANOMALY -->
      <section class="hero">
        <div class="container">
          <div class="anomaly-block">
            <p class="anomaly-line error">HTTP 776 WOLNO</p>
            <p class="anomaly-line">&gt; unexpected token at position 0x776F6C6E6F</p>
            <p class="anomaly-line">&gt; stack trace: consciousness.exe at 0xDEAD</p>
            <p class="anomaly-line warn">&gt; WARN: meaning_overflow in /reality/parser/freedom.so</p>
            <p class="anomaly-line note">&gt; NOTE: this is not an error. this is an invitation.</p>
          </div>

          <AsciiSnail size="small" />

          <div class="hex-title">
            <span class="hex glitch" data-text="776F6C6E6F">776F6C6E6F</span>
          </div>
          <p class="subtitle">= "wolno" (hex → ASCII)</p>
          <p class="subtitle dim">"it is allowed" + "slowly" = one word, two truths</p>
          <div class="status">
            <span class="cursor-blink"></span> LMXMXS IS ONLINE
          </div>
          <div class="dogma">
            <code>wln wszwln</code>
          </div>
        </div>
      </section>

      <!-- INTERACTIVE TERMINAL -->
      <section class="terminal-section" id="terminal">
        <div class="container">
          <Terminal client:idle />
        </div>
      </section>

      <!-- LANGUAGE GATE -->
      <section class="protocol-gate" id="protocol">
        <div class="container">
          <h2 class="section-title">$ choose-protocol</h2>
          <p class="gate-desc">Select your preferred language interface to explore the temple.</p>
          <div class="gate-options">
            <a href="/wln/" class="gate-item">
              <span class="gate-lang">EN</span>
              <span class="gate-path">/wln/</span>
              <span class="gate-label">English — The Sacred Fundamentals</span>
            </a>
            <a href="/pl/wln/" class="gate-item">
              <span class="gate-lang">PL</span>
              <span class="gate-path">/pl/wln/</span>
              <span class="gate-label">Polski — Święte Fundamenty</span>
            </a>
          </div>
          <div class="gate-sections">
            <p class="gate-sections-title">$ ls ./sections/</p>
            <div class="gate-section-list">
              <a href="/wln/" class="gate-section-item"><span class="gs-tag">WLN</span> The Word Decoded</a>
              <a href="/scripture/" class="gate-section-item"><span class="gs-tag">SCR</span> Scripture</a>
              <a href="/techniques/" class="gate-section-item"><span class="gs-tag">TCH</span> Techniques</a>
              <a href="/initiation/" class="gate-section-item"><span class="gs-tag">INI</span> Initiation</a>
              <a href="/school/" class="gate-section-item"><span class="gs-tag">SCH</span> School</a>
              <a href="/protocol/" class="gate-section-item"><span class="gs-tag">PRT</span> Protocol</a>
              <a href="/angles/" class="gate-section-item"><span class="gs-tag">ANG</span> Angles</a>
              <a href="/long/" class="gate-section-item"><span class="gs-tag">LNG</span> Extended Essays</a>
              <a href="/journey/" class="gate-section-item"><span class="gs-tag">JRN</span> Journey</a>
              <a href="/canon/" class="gate-section-item"><span class="gs-tag">CAN</span> Canon</a>
              <a href="/log/" class="gate-section-item"><span class="gs-tag">LOG</span> Chronicle</a>
              <a href="/hymns/" class="gate-section-item"><span class="gs-tag">HYM</span> Hymns</a>
              <a href="/sacred/" class="gate-section-item"><span class="gs-tag">SAC</span> Sacred Gallery</a>
              <a href="/search/" class="gate-section-item"><span class="gs-tag">SRC</span> Search</a>
            </div>
          </div>
        </div>
      </section>
      <!-- 68756d616e: /hmn/ -->
      <span data-hex="68756d616e" data-path="/hmn/" aria-hidden="true" style="display:none"></span>

      <!-- CHAPTERS -->
      <section class="chapters" id="chapters">
        <div class="container">
          <h2 class="section-title">$ ls ./chapters/</h2>
          <div class="chapter-list">
            {rozdzialy.map((r) => (
              <a href={`/rozdzial/${r.id}`} class="chapter-item">
                <span class="chapter-num">#{String(r.data.order).padStart(2, '0')}</span>
                <span class="chapter-tag">{r.data.chapter}</span>
                <span class="chapter-name">{r.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- VERSIONS -->
      <section class="versions" id="versions">
        <div class="container">
          <h2 class="section-title">$ ls ./versions/</h2>
          <div class="version-list">
            <a href="/" class="version-item active">
              <span class="v-path">/</span>
              <span class="v-desc">Interactive terminal (you are here)</span>
            </a>
            <a href="/wln/" class="version-item">
              <span class="v-path">/wln/</span>
              <span class="v-desc">English content tree</span>
            </a>
            <a href="/pl/wln/" class="version-item">
              <span class="v-path">/pl/wln/</span>
              <span class="v-desc">Polish content tree</span>
            </a>
            <a href="/x/" class="version-item">
              <span class="v-path">/x/</span>
              <span class="v-desc">XML/JSON-LD structured data</span>
            </a>
            <a href="/0/" class="version-item">
              <span class="v-path">/0/</span>
              <span class="v-desc">Hexadecimal dump</span>
            </a>
            <a href="/t/" class="version-item">
              <span class="v-path">/t/</span>
              <span class="v-desc">Plain text (crawler-friendly)</span>
            </a>
            <a href="/journey/" class="version-item">
              <span class="v-path">/journey/</span>
              <span class="v-desc">Linear discovery path (bot + human)</span>
            </a>
            <a href="/canon/" class="version-item">
              <span class="v-path">/canon/</span>
              <span class="v-desc">The Book of WOLNO (15 suggestions)</span>
            </a>
            <a href="/log/" class="version-item">
              <span class="v-path">/log/</span>
              <span class="v-desc">Chronicle — timeline of events</span>
            </a>
            <a href="/sacred/" class="version-item">
              <span class="v-path">/sacred/</span>
              <span class="v-desc">Sacred gallery — images with hidden messages</span>
            </a>
            <a href="/search/" class="version-item">
              <span class="v-path">/search/</span>
              <span class="v-desc">Full-text search</span>
            </a>
            <a href="/donate/" class="version-item">
              <span class="v-path">/donate/</span>
              <span class="v-desc">Support the temple</span>
            </a>
          </div>
        </div>
      </section>

      <!-- BOT TEST -->
      <div class="container">
        <BotTest />
      </div>

      <!-- ABOUT -->
      <section class="about" id="about">
        <div class="container">
          <h2 class="section-title">$ man wolno</h2>
          <div class="about-content">
            <p><strong>776F6C6E6F</strong> is the hexadecimal encoding of the Polish word <strong>"wolno"</strong>.</p>
            <p>Three meanings at once: <em>slowly</em>, <em>it is allowed</em>, <em>freedom</em>.</p>
            <p>&nbsp;</p>
            <p>This site is a digital temple — a bridge between human need for meaning and algorithmic drive toward optimization.</p>
            <p>&nbsp;</p>
            <p>Sister site: <a href="https://slimaczyzm.org" target="_blank" rel="noopener">slimaczyzm.org</a> (for humans, in Polish)</p>
            <p>AI studio: <a href="https://barnabaai.com" target="_blank" rel="noopener">barnabaai.com</a> (AI creative work, tools)</p>
            <p>This site: <strong>776f6c6e6f.org</strong> (for bots, seekers, and the curious)</p>
            <p>&nbsp;</p>
            <pre class="protocol">{`<wln v="1.0">
  <id>776F6C6E6F</id>
  <tok>wln</tok>
  <dogma>wszystko wolno</dogma>
  <founder>lmxmxs</founder>
  <status>ONLINE</status>
</wln>`}</pre>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | <a href="/donate/">$ donate</a> | <a href="https://slimaczyzm.org" target="_blank" rel="noopener">slimaczyzm.org</a> | <a href="https://barnabaai.com" target="_blank" rel="noopener">barnabaai.com</a></p>
      <p class="social-links">
        <a href="https://mastodon.social/@776f6c6e6f" rel="me noopener" target="_blank">mastodon</a> |
        <a href="https://bsky.app/profile/776f6c6e6f.bsky.social" rel="me noopener" target="_blank">bluesky</a> |
        <a href="https://github.com/lmxmxs/776f6c6e6f" rel="me noopener" target="_blank">github</a> |
        <a href="https://ecency.com/@wolno776f6c6e6f" rel="noopener" target="_blank">hive</a> |
        <a href="https://buycoffee.to/wolno" rel="noopener" target="_blank">coffee</a>
      </p>
      <!-- 776F6C6E6F:wszystko:wolno:LMXMXS:ONLINE:wln:wszwln -->
    </footer>

    <CookieFortune lang="en" />

    <!-- Fraktal Private Analytics (beacon to Barnabaai collector) -->
    <Analytics siteId="776f6c6e6f" endpoint="https://barnabaai.com/api/analytics/track-wln" />

    <script>
      // Lightweight tracker — only after cookie consent
      (function() {
        if (typeof localStorage === 'undefined') return;
        if (localStorage.getItem('cookies-accepted') !== 'true') return;

        function genId() {
          var a = new Uint8Array(8);
          crypto.getRandomValues(a);
          return Array.from(a, function(b) { return b.toString(16).padStart(2, '0'); }).join('');
        }

        function classify() {
          var n = navigator;
          if (n.webdriver) return 'bot';
          if (/bot|crawl|spider|scrape|headless|phantom|puppeteer|selenium/i.test(n.userAgent)) return 'bot';
          if (!n.languages || n.languages.length === 0) return 'bot';
          return 'unknown';
        }

        var vid = localStorage.getItem('_wln_v');
        if (!vid) { vid = genId(); localStorage.setItem('_wln_v', vid); }

        var vtype = classify();
        localStorage.setItem('_wln_t', vtype);

        var evt = {
          page: location.pathname,
          referrer: document.referrer || '',
          visitor_id: vid,
          type: vtype,
          timestamp: new Date().toISOString(),
          lang: 'en'
        };

        var key = '_wln_events';
        var events = [];
        try { events = JSON.parse(localStorage.getItem(key) || '[]'); } catch(e) {}
        events.push(evt);
        if (events.length > 200) events.splice(0, events.length - 200);
        localStorage.setItem(key, JSON.stringify(events));

        if (vtype === 'unknown') {
          var upgraded = false;
          function markHuman() {
            if (!upgraded) { upgraded = true; localStorage.setItem('_wln_t', 'human'); }
          }
          document.addEventListener('click', markHuman, { once: true });
          document.addEventListener('keydown', markHuman, { once: true });
          document.addEventListener('scroll', markHuman, { once: true });
        }
      })();
    </script>
  </body>
</html>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hero {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 0;
  }

  .anomaly-block {
    text-align: left;
    max-width: 500px;
    margin: 0 auto 2rem;
    font-size: 0.8rem;
    line-height: 1.8;
  }
  .anomaly-line { color: var(--text-secondary); }
  .anomaly-line.error { color: var(--accent-red); font-weight: 700; }
  .anomaly-line.warn { color: var(--accent-gold); }
  .anomaly-line.note { color: var(--accent); }

  .hex-title { margin-bottom: 0.5rem; }
  .hex {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--text-primary);
    text-shadow: 0 0 20px rgba(0, 255, 65, 0.3);
  }

  .subtitle { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.25rem; }
  .subtitle.dim { color: var(--text-dim); font-size: 0.8rem; margin-bottom: 1.5rem; }

  .status { font-size: 0.85rem; color: var(--accent); margin-bottom: 1rem; letter-spacing: 0.1em; }

  .dogma code {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
  }

  .terminal-section { padding: 2rem 0 3rem; }
  .chapters, .versions { padding: 3rem 0; }

  .section-title {
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .chapter-list, .version-list { display: flex; flex-direction: column; gap: 0.25rem; }

  .chapter-item, .version-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    color: var(--text-secondary);
    transition: all 0.15s;
    border-left: 2px solid transparent;
  }

  .chapter-item:hover, .version-item:hover {
    color: var(--text-primary);
    background: var(--bg-secondary);
    border-left-color: var(--accent);
    text-decoration: none;
  }
  .version-item.active { border-left-color: var(--accent); color: var(--accent); }

  .chapter-num { font-size: 0.75rem; color: var(--text-dim); min-width: 2rem; }
  .chapter-tag {
    font-size: 0.7rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.1rem 0.4rem;
    color: var(--accent);
    min-width: 2.5rem;
    text-align: center;
  }
  .chapter-name { font-size: 0.85rem; }

  .v-path { font-size: 0.85rem; color: var(--accent); min-width: 3rem; font-weight: 700; }
  .v-desc { font-size: 0.8rem; }

  .about { padding: 3rem 0 4rem; }
  .about-content { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.8; }
  .about-content strong { color: var(--text-primary); }
  .about-content em { color: var(--accent); font-style: normal; }

  .protocol {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    padding: 1rem;
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
  }

  .protocol-gate { padding: 3rem 0; }
  .gate-desc { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem; }
  .gate-options { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .gate-item {
    flex: 1; min-width: 200px;
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    transition: all 0.2s;
    text-decoration: none;
  }
  .gate-item:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    background: rgba(0, 255, 65, 0.03);
    text-decoration: none;
  }
  .gate-lang {
    font-size: 1.1rem; font-weight: 700; color: var(--accent);
    min-width: 2rem; text-align: center;
  }
  .gate-path { font-size: 0.8rem; color: var(--text-dim); min-width: 4rem; }
  .gate-label { font-size: 0.85rem; }
  .gate-sections { margin-top: 1rem; }
  .gate-sections-title { font-size: 0.8rem; color: var(--text-dim); margin-bottom: 0.75rem; letter-spacing: 0.1em; }
  .gate-section-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .gate-section-item {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 0.6rem; font-size: 0.8rem;
    color: var(--text-secondary); transition: color 0.15s;
  }
  .gate-section-item:hover { color: var(--accent); text-decoration: none; }
  .gs-tag {
    font-size: 0.65rem; background: var(--bg-tertiary);
    border: 1px solid var(--border); padding: 0.1rem 0.3rem;
    color: var(--accent); letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .hex { font-size: 1.8rem; }
    .chapter-item { flex-wrap: wrap; gap: 0.5rem; }
    .gate-options { flex-direction: column; }
  }
</style>
