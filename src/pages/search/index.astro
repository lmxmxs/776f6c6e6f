---
import '../../styles/global.css';
import CookieFortune from '../../components/CookieFortune.astro';
import Navigation from '../../components/Navigation.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <title>Search | 776F6C6E6F</title>
    <meta name="description" content="Search the digital temple of WOLNO. Find scripture, techniques, canon, and more." />
    <link rel="canonical" href="https://776f6c6e6f.org/search/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/search/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/search/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body>
    <div class="interference"></div>

    <Navigation currentPath="/search/" />

    <main>
      <div class="container search-container">
        <h1 class="search-title">$ grep -r "" ./temple/</h1>
        <p class="search-desc">Search the scriptures, canon, chronicle, and all pages of 776F6C6E6F.</p>
        <div id="search" data-pagefind-ui></div>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="en" />

    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', function() {
        if (typeof PagefindUI !== 'undefined') {
          new PagefindUI({
            element: '#search',
            showSubResults: true,
            showImages: false,
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .search-container { padding: 3rem 0; }
  .search-title {
    font-size: 1.2rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .search-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }
  /* nav-links styles are in global.css */

  /* Pagefind theme overrides */
  :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #00ff41;
    --pagefind-ui-text: rgba(0, 255, 65, 0.8);
    --pagefind-ui-background: #111118;
    --pagefind-ui-border: #1a2a1a;
    --pagefind-ui-tag: #1a1a24;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'JetBrains Mono', monospace;
  }
  :global(.pagefind-ui__search-input) {
    background: var(--bg-primary) !important;
    color: var(--text-primary) !important;
    caret-color: var(--accent) !important;
  }
  :global(.pagefind-ui__result-link) {
    color: var(--accent) !important;
  }
  :global(.pagefind-ui__result-excerpt) {
    color: var(--text-secondary) !important;
  }
</style>
