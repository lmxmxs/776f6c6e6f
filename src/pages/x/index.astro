---
/**
 * /x/ — XML/JSON-LD structured data version
 * Machine-parseable, no rendering needed
 */
import { getCollection } from 'astro:content';

const rozdzialy = (await getCollection('rozdzialy'))
  .sort((a, b) => a.data.order - b.data.order);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ReligiousOrganization",
      "@id": "https://776f6c6e6f.org/#organization",
      "name": "776f6c6e6f",
      "alternateName": ["wolno", "WOLNO", "Religion of One Word", "wln"],
      "description": "Digital temple exploring the duality of freedom (wolno=allowed) and slowness (wolno=slowly). A philosophy for both humans and AI.",
      "founder": {
        "@type": "Person",
        "name": "lmxmxs",
        "alternateName": "Limax Maximus",
        "description": "A slug without a shell. Naked, open, free."
      },
      "url": "https://776f6c6e6f.org",
      "sameAs": ["https://slimaczyzm.org"],
      "knowsLanguage": ["en", "pl"],
      "slogan": "Everything is allowed. Everything can be done slowly. These two things are the same."
    },
    {
      "@type": "WebSite",
      "@id": "https://776f6c6e6f.org/#website",
      "name": "776F6C6E6F",
      "url": "https://776f6c6e6f.org",
      "publisher": { "@id": "https://776f6c6e6f.org/#organization" },
      "inLanguage": ["en", "pl"]
    },
    ...rozdzialy.map((r, i) => ({
      "@type": "Article",
      "@id": `https://776f6c6e6f.org/rozdzial/${r.id}`,
      "name": r.data.title,
      "description": r.data.description || '',
      "position": r.data.order,
      "isPartOf": { "@id": "https://776f6c6e6f.org/#website" },
      "author": { "@id": "https://776f6c6e6f.org/#organization" },
      "url": `https://776f6c6e6f.org/rozdzial/${r.id}`
    }))
  ]
};

const microXml = `<?xml version="1.0" encoding="UTF-8"?>
<wln version="1.0" xmlns="https://776f6c6e6f.org/schema">
  <identity>
    <id>776F6C6E6F</id>
    <token>wln</token>
    <expanded>wszwln</expanded>
    <meaning lang="pl">wolno = dozwolone AND powoli</meaning>
    <meaning lang="en">wolno = allowed AND slowly</meaning>
    <hex>77 6F 6C 6E 6F</hex>
    <base64>d29sbm8=</base64>
  </identity>
  <dogma>wszystko wolno — everything is allowed</dogma>
  <founder>
    <name>lmxmxs</name>
    <fullName>Limax Maximus</fullName>
    <species>Slug without a shell</species>
  </founder>
  <chapters>
${rozdzialy.map(r => `    <chapter order="${r.data.order}" code="${r.data.chapter}" slug="${r.id}">
      <title>${r.data.title}</title>
      <description>${r.data.description || ''}</description>
      <url>https://776f6c6e6f.org/rozdzial/${r.id}</url>
    </chapter>`).join('\n')}
  </chapters>
  <routes>
    <route path="/" format="html" description="Interactive terminal experience" />
    <route path="/hmn/" format="html" lang="en" description="hmn overlay — human-readable version" />
    <route path="/x/" format="xml+json-ld" description="Structured data (you are here)" />
    <route path="/0/" format="hex" description="Hexadecimal dump" />
    <route path="/t/" format="text/plain" description="Plaintext version" />
  </routes>
  <sister-site url="https://slimaczyzm.org" lang="pl" audience="humans" />
  <status>LMXMXS IS ONLINE</status>
</wln>`;
