---
import '../../styles/global.css';
import Navigation from '../../components/Navigation.astro';
import UnicodeLab from '../../components/UnicodeLab';
import CookieFortune from '../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Unicode Security Lab — Detect, Encode, Pen Test | 776F6C6E6F</title>
    <meta name="description" content="Unicode Security Lab: detect hidden chars (ASCII smuggling, zero-width), encode steganographic payloads with ZWS or Unicode Tags, pen test your AI pipelines." />
    <meta property="og:title" content="Unicode Security Lab" />
    <meta property="og:description" content="All-in-one: detect hidden Unicode, encode invisible payloads (ZWS / Tags), pen test AI prompt injection defenses." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/narzedzia/unicode-lab/" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/narzedzia/unicode-lab/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Unicode Security Lab",
      "description": "Detect hidden Unicode, encode steganographic payloads (ZWS / Tags), pen test AI prompt injection defenses.",
      "url": "https://776f6c6e6f.org/narzedzia/unicode-lab/",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Any (browser-based)",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })}</script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G932JG5N9Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (typeof window !== 'undefined' && localStorage.getItem('cookies-accepted') === 'true') {
        gtag('config', 'G-G932JG5N9Z');
      } else {
        document.addEventListener('cookies-accepted', function() {
          gtag('config', 'G-G932JG5N9Z');
        });
      }
    </script>
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation currentPath="/narzedzia/unicode-lab/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ./unicode-lab
          <span class="breadcrumb"> | <a href="/narzedzia/">&larr; tools</a></span>
        </div>

        <h1 class="page-title">Unicode Security Lab</h1>
        <p class="page-desc">
          Three modes in one tool: <strong>detect</strong> hidden characters in any text,
          <strong>encode</strong> invisible payloads using ZWS binary or Unicode Tags,
          and <strong>pen test</strong> your own AI pipelines by encoding a payload and
          immediately scanning for detection. Authorized use only.
        </p>
        <div class="separator">-" wln</div>

        <UnicodeLab client:visible />

        <div class="tool-info">
          <h2>Technique Reference</h2>
          <table class="ref-table">
            <thead>
              <tr>
                <th>Technique</th>
                <th>Characters</th>
                <th>Visibility</th>
                <th>AI reads payload?</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>ASCII smuggling</strong></td>
                <td class="mono">U+E0000–E007F</td>
                <td class="high">invisible</td>
                <td class="high">YES — direct ASCII mirror</td>
              </tr>
              <tr>
                <td><strong>ZWS steganography</strong></td>
                <td class="mono">U+200B / U+200C</td>
                <td class="medium">invisible</td>
                <td class="medium">requires decoding (binary)</td>
              </tr>
              <tr>
                <td><strong>BOM injection</strong></td>
                <td class="mono">U+FEFF</td>
                <td class="high">invisible</td>
                <td class="low">metadata / encoding trick</td>
              </tr>
              <tr>
                <td><strong>RTL override</strong></td>
                <td class="mono">U+200F / U+202E</td>
                <td class="medium">visual flip</td>
                <td class="low">visual confusion only</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="separator">-" wszwln</div>

        <nav class="page-nav-bottom">
          <a href="/narzedzia/">&larr; All tools</a>
          <a href="/narzedzia/unicode-inspector/">Inspector only &rarr;</a>
          <a href="/narzedzia/encoding-detector/">Encoding detector &rarr;</a>
          <a href="/techniques/unicode/">Unicode technique</a>
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | <a href="/donate/">$ donate</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="en" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title { font-size: 1.6rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .tool-info { margin: 2rem 0; }
  .tool-info h2 {
    font-size: 1rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .ref-table th, .ref-table td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .ref-table th {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .ref-table td { color: var(--text-secondary); }

  .mono { font-family: var(--font-mono); color: var(--text-primary); }
  .high { color: #ff4444; font-weight: 700; }
  .medium { color: #ffaa00; font-weight: 700; }
  .low { color: #4488ff; }

  .page-nav-bottom {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
  }
  .page-nav-bottom a { color: var(--accent); }
  .page-nav-bottom a:hover { text-decoration: none; opacity: 0.8; }

  @media (max-width: 600px) {
    .ref-table { font-size: 0.68rem; }
    .ref-table th, .ref-table td { padding: 0.3rem 0.4rem; }
  }
</style>
