---
import '../../styles/global.css';
import Navigation from '../../components/Navigation.astro';
import EncodingDetector from '../../components/EncodingDetector';
import CookieFortune from '../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Multi-Encoding Auto-Detector | 776F6C6E6F Tools</title>
    <meta name="description" content="Automatically identify and decode Base64, hex, binary, Morse, ROT13, URL encoding and HTML entities with confidence scores." />
    <meta property="og:title" content="Multi-Encoding Auto-Detector" />
    <meta property="og:description" content="Auto-detect and decode Base64, hex, binary, Morse, ROT13, URL and HTML encodings." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/narzedzia/encoding-detector/" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/narzedzia/encoding-detector/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Multi-Encoding Auto-Detector",
      "description": "Automatically identify and decode Base64, hex, binary, Morse, ROT13, URL encoding and HTML entities.",
      "url": "https://776f6c6e6f.org/narzedzia/encoding-detector/",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Any (browser-based)",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })}</script>
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation currentPath="/narzedzia/encoding-detector/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ./encoding-detector --try-all
          <span class="breadcrumb"> | <a href="/narzedzia/">&larr; tools</a></span>
        </div>

        <h1 class="page-title">Multi-Encoding Auto-Detector</h1>
        <p class="page-desc">
          Paste encoded text to automatically identify the encoding scheme and decode it.
          Supports Base64, hexadecimal, binary, Morse code, ROT13, URL encoding and HTML entities.
          All processing is local — no server involved.
        </p>
        <div class="separator">-" wln</div>

        <EncodingDetector client:visible />

        <div class="tool-info">
          <h2>Encoding Examples</h2>
          <table class="ref-table">
            <thead>
              <tr>
                <th>Encoding</th>
                <th>Original</th>
                <th>Encoded</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Base64</td>
                <td class="mono">hello world</td>
                <td class="mono">aGVsbG8gd29ybGQ=</td>
              </tr>
              <tr>
                <td>Hexadecimal</td>
                <td class="mono">wolno</td>
                <td class="mono">776f6c6e6f</td>
              </tr>
              <tr>
                <td>Binary</td>
                <td class="mono">hi</td>
                <td class="mono">01101000 01101001</td>
              </tr>
              <tr>
                <td>Morse</td>
                <td class="mono">SOS</td>
                <td class="mono">... --- ...</td>
              </tr>
              <tr>
                <td>ROT13</td>
                <td class="mono">wolno</td>
                <td class="mono">jbyab</td>
              </tr>
              <tr>
                <td>URL Encoding</td>
                <td class="mono">hello world</td>
                <td class="mono">hello%20world</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="separator">-" wszwln</div>

        <nav class="page-nav-bottom">
          <a href="/narzedzia/">&larr; All tools</a>
          <a href="/narzedzia/unicode-inspector/">Unicode Inspector</a>
          <a href="/narzedzia/prompt-visibility/">Prompt Visibility &rarr;</a>
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | <a href="/donate/">$ donate</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="en" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title { font-size: 1.6rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .tool-info { margin: 2rem 0; }
  .tool-info h2 {
    font-size: 1rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .ref-table th, .ref-table td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .ref-table th {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .ref-table td { color: var(--text-secondary); }
  .mono { font-family: var(--font-mono); color: var(--text-primary); word-break: break-all; }

  .page-nav-bottom {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
  }
  .page-nav-bottom a { color: var(--accent); }
  .page-nav-bottom a:hover { text-decoration: none; opacity: 0.8; }
</style>
