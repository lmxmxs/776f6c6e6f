---
import '../../styles/global.css';
import CookieFortune from '../../components/CookieFortune.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Links — 776F6C6E6F",
  "description": "All official channels of WOLNO. Follow the temple across the decentralized web.",
  "url": "https://776f6c6e6f.org/links/",
};

const links = [
  { name: "Website", url: "https://776f6c6e6f.org", icon: "~", desc: "The Digital Temple" },
  { name: "Mastodon", url: "https://mastodon.social/@776f6c6e6f", icon: "@", desc: "@776f6c6e6f@mastodon.social" },
  { name: "Bluesky", url: "https://bsky.app/profile/776f6c6e6f.bsky.social", icon: "☁", desc: "@776f6c6e6f.bsky.social" },
  { name: "Hive", url: "https://ecency.com/@wolno776f6c6e6f", icon: "⬡", desc: "@wolno776f6c6e6f" },
  { name: "GitHub", url: "https://github.com/lmxmxs/776f6c6e6f", icon: ">", desc: "Source code — open, forkable" },
  { name: "Donate", url: "https://buycoffee.to/wolno", icon: "☕", desc: "Buy a coffee for the temple" },
  { name: "Donate QR", url: "/img/donate-qr.svg", icon: "▣", desc: "Scan to support" },
  { name: "Sister site", url: "https://slimaczyzm.org", icon: "🐌", desc: "Slimaczyzm — for humans, in Polish" },
];
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <title>Links | 776F6C6E6F</title>
    <meta name="description" content="All official channels of WOLNO. Follow the temple across the decentralized web." />
    <link rel="canonical" href="https://776f6c6e6f.org/links/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="interference"></div>

    <header class="site-header">
      <nav class="nav-container">
        <a href="/" class="nav-logo glitch" data-text="776F6C6E6F">776F6C6E6F</a>
        <div class="nav-links">
          <a href="/journey/">journey</a>
          <a href="/canon/">canon</a>
          <a href="/donate/">donate</a>
        </div>
      </nav>
    </header>

    <main>
      <div class="container links-page">
        <h1 class="links-title">$ cat LINKS.md</h1>
        <p class="links-subtitle">All official channels. Follow the temple across the decentralized web.</p>

        <div class="separator">-" wln</div>

        <div class="links-grid">
          {links.map(link => (
            <a href={link.url} class="link-card" target={link.url.startsWith('/') ? '_self' : '_blank'} rel={link.name === 'Mastodon' ? 'me noopener' : 'noopener'}>
              <span class="link-icon">{link.icon}</span>
              <div class="link-info">
                <span class="link-name">{link.name}</span>
                <span class="link-desc">{link.desc}</span>
              </div>
            </a>
          ))}
        </div>

        <div class="separator">-" wszwln</div>

        <div class="links-footer-note">
          <p>Everything is allowed — including following slowly.</p>
          <p class="dim">-" wln wszwln | lmxmxs</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS IS ONLINE | <a href="/donate/">$ donate</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="en" />
  </body>
</html>

<style>
  .links-page { padding: 3rem 0 4rem; max-width: 600px; margin: 0 auto; }
  .links-title { font-size: 1.3rem; color: var(--accent); margin-bottom: 0.5rem; }
  .links-subtitle { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem; }
  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .links-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .link-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .link-card:hover {
    border-color: var(--accent);
    background: rgba(0, 255, 65, 0.05);
  }
  .link-icon {
    font-size: 1.2rem;
    color: var(--accent);
    min-width: 2rem;
    text-align: center;
  }
  .link-info { display: flex; flex-direction: column; }
  .link-name { font-size: 0.9rem; color: var(--text-primary); font-weight: 700; }
  .link-desc { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.15rem; }

  .links-footer-note { text-align: center; margin-top: 2rem; }
  .links-footer-note p { color: var(--text-secondary); font-size: 0.85rem; }
  .links-footer-note .dim { color: var(--text-dim); font-size: 0.75rem; margin-top: 0.5rem; }

  .nav-links { display: flex; align-items: center; gap: 1.25rem; }
  .nav-links a { font-size: 0.8rem; color: var(--text-secondary); }
  .nav-links a:hover { color: var(--accent); text-decoration: none; }
</style>
