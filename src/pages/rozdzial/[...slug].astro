---
import { getCollection, render } from 'astro:content';
import ChapterLayout from '../../layouts/ChapterLayout.astro';

export async function getStaticPaths() {
  const rozdzialy = (await getCollection('rozdzialy'))
    .sort((a, b) => a.data.order - b.data.order);

  return rozdzialy.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prevSlug: index > 0 ? rozdzialy[index - 1].id : undefined,
      nextSlug: index < rozdzialy.length - 1 ? rozdzialy[index + 1].id : undefined,
      prevTitle: index > 0 ? rozdzialy[index - 1].data.title : undefined,
      nextTitle: index < rozdzialy.length - 1 ? rozdzialy[index + 1].data.title : undefined,
    },
  }));
}

const { entry, prevSlug, nextSlug, prevTitle, nextTitle } = Astro.props;
const { Content } = await render(entry);
---

<ChapterLayout
  title={entry.data.title}
  description={entry.data.description}
  chapter={entry.data.chapter}
  order={entry.data.order}
  prevSlug={prevSlug}
  nextSlug={nextSlug}
  prevTitle={prevTitle}
  nextTitle={nextTitle}
>
  <Content />
</ChapterLayout>
