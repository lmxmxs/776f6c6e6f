---
/**
 * /t/ — Verbose plaintext version (EN)
 * Content-Type-like plain text for Perplexity, simple crawlers
 * Every chapter in full, with wiki-links as URLs
 */
import { getCollection, render } from 'astro:content';

const rozdzialy = (await getCollection('rozdzialy'))
  .sort((a, b) => a.data.order - b.data.order);
---

<!DOCTYPE html>
<html lang="en">
