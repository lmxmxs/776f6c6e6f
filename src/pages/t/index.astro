    <meta name="description" content="Plain text version of 776f6c6e6f.org. WOLNO = allowed AND slowly. Full chapters, no formatting." />
    <meta name="robots" content="index, follow, max-snippet:-1" />
    <link rel="canonical" href="https://776f6c6e6f.org/t/" />
    <style is:global>
      body {
        font-family: 'Courier New', Courier, monospace;
        background: #0a0a0f;
        color: #c0c0c0;
        max-width: 80ch;
        margin: 0 auto;
        padding: 2rem;
        font-size: 14px;
        line-height: 1.8;
        white-space: pre-wrap;
        word-wrap: break-word;
      }
      a { color: #00ff41; }
    </style>
  </head>
  <body>{`
