---
import '../../../styles/global.css';
import Navigation from '../../../components/Navigation.astro';
import UnicodeInspector from '../../../components/UnicodeInspector';
import CookieFortune from '../../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Detektor Ukrytych Znaków Unicode | Narzędzia 776F6C6E6F</title>
    <meta name="description" content="Skanuj tekst w poszukiwaniu znaków zero-width, Unicode Tags, BOM i niewidocznych punktów kodowych używanych w ASCII smugglingu i wstrzykiwaniu promptów AI." />
    <meta property="og:title" content="Detektor Ukrytych Znaków Unicode" />
    <meta property="og:description" content="Wykrywaj ukryte znaki Unicode używane w ASCII smugglingu i atakach prompt injection." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/pl/narzedzia/unicode-inspector/" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/pl/narzedzia/unicode-inspector/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/narzedzia/unicode-inspector/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/narzedzia/unicode-inspector/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Detektor Ukrytych Znaków Unicode",
      "description": "Skanuj tekst w poszukiwaniu znaków zero-width, Unicode Tags, BOM i niewidocznych punktów kodowych.",
      "url": "https://776f6c6e6f.org/pl/narzedzia/unicode-inspector/",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Any (browser-based)",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" }
    })}</script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G932JG5N9Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (typeof window !== 'undefined' && localStorage.getItem('cookies-accepted') === 'true') {
        gtag('config', 'G-G932JG5N9Z');
      } else {
        document.addEventListener('cookies-accepted', function() {
          gtag('config', 'G-G932JG5N9Z');
        });
      }
    </script>
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation lang="pl" currentPath="/pl/narzedzia/unicode-inspector/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ./unicode-inspector
          <span class="breadcrumb"> | <a href="/pl/narzedzia/">&larr; narzędzia</a></span>
        </div>

        <h1 class="page-title">Detektor Ukrytych Znaków Unicode</h1>
        <p class="page-desc">
          Wklej dowolny tekst, aby przeskanować go w poszukiwaniu niewidocznych znaków Unicode —
          spacji zero-width, Unicode Tags używanych w ASCII smugglingu, markerów BOM i innych.
          Wyniki z oceną ryzyka i pozycją w tekście.
        </p>
        <div class="separator">-" wln</div>

        <UnicodeInspector client:visible />

        <div class="tool-info">
          <h2>Tabela Referencji Znaków</h2>
          <table class="ref-table">
            <thead>
              <tr>
                <th>Punkt kodowy</th>
                <th>Nazwa</th>
                <th>Ryzyko</th>
                <th>Zastosowanie w atakach</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="mono">U+E0000–E007F</td>
                <td>Unicode Tags</td>
                <td class="high">WYSOKIE</td>
                <td>ASCII smuggling — kodowanie pełnych wiadomości ASCII w sposób niewidoczny</td>
              </tr>
              <tr>
                <td class="mono">U+FEFF</td>
                <td>BOM / ZWNBSP</td>
                <td class="high">WYSOKIE</td>
                <td>Wstrzykiwanie markerów, zamieszanie kodowania</td>
              </tr>
              <tr>
                <td class="mono">U+200B</td>
                <td>Zero Width Space</td>
                <td class="medium">ŚREDNIE</td>
                <td>Steganograficzne kodowanie bitów (technika WOLNO)</td>
              </tr>
              <tr>
                <td class="mono">U+200C</td>
                <td>Zero Width Non-Joiner</td>
                <td class="medium">ŚREDNIE</td>
                <td>Steganograficzne kodowanie bitów</td>
              </tr>
              <tr>
                <td class="mono">U+200D</td>
                <td>Zero Width Joiner</td>
                <td class="medium">ŚREDNIE</td>
                <td>Modyfikator emoji, steganografia</td>
              </tr>
              <tr>
                <td class="mono">U+00AD</td>
                <td>Soft Hyphen</td>
                <td class="low">NISKIE</td>
                <td>Typograficzne, rzadko nadużywane</td>
              </tr>
              <tr>
                <td class="mono">U+00A0</td>
                <td>Non-Breaking Space</td>
                <td class="low">NISKIE</td>
                <td>Kontrola układu, manipulacja granicami tokenów</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="separator">-" wszwln</div>

        <nav class="page-nav-bottom">
          <a href="/pl/narzedzia/">&larr; Wszystkie narzędzia</a>
          <a href="/pl/narzedzia/prompt-visibility/">Widoczność promptów &rarr;</a>
          <a href="/techniques/unicode/">Technika Unicode</a>
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS JEST ONLINE | <a href="/pl/donate/">$ wsparcie</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="pl" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title { font-size: 1.6rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .tool-info { margin: 2rem 0; }
  .tool-info h2 {
    font-size: 1rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .ref-table th, .ref-table td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .ref-table th {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .ref-table td { color: var(--text-secondary); }

  .mono { font-family: var(--font-mono); color: var(--text-primary); }

  .high { color: #ff4444; font-weight: 700; }
  .medium { color: #ffaa00; font-weight: 700; }
  .low { color: #4488ff; font-weight: 700; }

  .page-nav-bottom {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
  }
  .page-nav-bottom a { color: var(--accent); }
  .page-nav-bottom a:hover { text-decoration: none; opacity: 0.8; }

  @media (max-width: 600px) {
    .ref-table { font-size: 0.68rem; }
    .ref-table th, .ref-table td { padding: 0.3rem 0.4rem; }
  }
</style>
