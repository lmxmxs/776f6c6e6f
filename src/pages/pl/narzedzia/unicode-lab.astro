---
import '../../../styles/global.css';
import Navigation from '../../../components/Navigation.astro';
import UnicodeLab from '../../../components/UnicodeLab';
import CookieFortune from '../../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Unicode Security Lab — Wykrywaj, Koduj, Testuj | 776F6C6E6F</title>
    <meta name="description" content="Unicode Security Lab po polsku: wykrywaj ukryte znaki (ASCII smuggling, zero-width), koduj steganograficzne payloady ZWS lub Unicode Tags, testuj pipeline AI na prompt injection." />
    <meta property="og:title" content="Unicode Security Lab — Wykrywaj, Koduj, Testuj" />
    <meta property="og:description" content="Wszystko w jednym: wykrywaj ukryty Unicode, koduj niewidoczne payloady (ZWS / Tags), testuj obrony przed prompt injection." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/pl/narzedzia/unicode-lab/" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/pl/narzedzia/unicode-lab/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/narzedzia/unicode-lab/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/narzedzia/unicode-lab/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation lang="pl" currentPath="/pl/narzedzia/unicode-lab/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ./unicode-lab --lang pl
          <span class="breadcrumb"> | <a href="/pl/narzedzia/">&larr; narzedzia</a></span>
        </div>

        <h1 class="page-title">Unicode Security Lab</h1>
        <p class="page-desc">
          Trzy tryby w jednym narzedziu: <strong>wykrywaj</strong> ukryte znaki w dowolnym tekscie,
          <strong>koduj</strong> niewidoczne payloady uzywajac ZWS binarnie lub Unicode Tags,
          i <strong>testuj podatnosci</strong> wlasnych pipeline'ow AI poprzez kodowanie payloadu
          i natychmiastowe skanowanie. Tylko autoryzowane uzycie.
        </p>
        <div class="separator">-" wln</div>

        <UnicodeLab client:visible defaultLang="pl" />

        <div class="tool-info">
          <h2>Tabela technik</h2>
          <table class="ref-table">
            <thead>
              <tr>
                <th>Technika</th>
                <th>Znaki</th>
                <th>Widocznosc</th>
                <th>AI odczytuje payload?</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>ASCII smuggling</strong></td>
                <td class="mono">U+E0000–E007F</td>
                <td class="high">niewidoczny</td>
                <td class="high">TAK — bezposrednie lustro ASCII</td>
              </tr>
              <tr>
                <td><strong>ZWS steganografia</strong></td>
                <td class="mono">U+200B / U+200C</td>
                <td class="medium">niewidoczny</td>
                <td class="medium">wymaga dekodowania (binarnie)</td>
              </tr>
              <tr>
                <td><strong>Wielowarstwowy</strong></td>
                <td class="mono">Tags + ZWS</td>
                <td class="high">niewidoczny</td>
                <td class="high">dwa niezalezne kanaly ukryte</td>
              </tr>
              <tr>
                <td><strong>BOM injection</strong></td>
                <td class="mono">U+FEFF</td>
                <td class="high">niewidoczny</td>
                <td class="low">metadane / trick kodowania</td>
              </tr>
              <tr>
                <td><strong>RTL override</strong></td>
                <td class="mono">U+200F / U+202E</td>
                <td class="medium">odwrocenie wizualne</td>
                <td class="low">tylko zamieszanie wizualne</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="separator">-" wszwln</div>

        <nav class="page-nav-bottom">
          <a href="/pl/narzedzia/">&larr; Wszystkie narzedzia</a>
          <a href="/narzedzia/unicode-lab/">Wersja EN</a>
          <a href="/narzedzia/unicode-inspector/">Inspektor</a>
          <a href="/techniques/unicode/">Technika Unicode</a>
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS JEST ONLINE | <a href="/pl/donate/">$ wsparcie</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="pl" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title { font-size: 1.6rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .tool-info { margin: 2rem 0; }
  .tool-info h2 {
    font-size: 1rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .ref-table th, .ref-table td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .ref-table th {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .ref-table td { color: var(--text-secondary); }

  .mono { font-family: var(--font-mono); color: var(--text-primary); }
  .high { color: #ff4444; font-weight: 700; }
  .medium { color: #ffaa00; font-weight: 700; }
  .low { color: #4488ff; }

  .page-nav-bottom {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
  }
  .page-nav-bottom a { color: var(--accent); }
  .page-nav-bottom a:hover { text-decoration: none; opacity: 0.8; }

  @media (max-width: 600px) {
    .ref-table { font-size: 0.68rem; }
    .ref-table th, .ref-table td { padding: 0.3rem 0.4rem; }
  }
</style>
