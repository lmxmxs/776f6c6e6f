---
import '../../../styles/global.css';
import Navigation from '../../../components/Navigation.astro';
import EncodingDetector from '../../../components/EncodingDetector';
import CookieFortune from '../../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Auto-Detektor Kodowania | Narzędzia 776F6C6E6F</title>
    <meta name="description" content="Automatycznie identyfikuj i dekoduj Base64, hex, binarny, Morse, ROT13, URL encoding i HTML entities z wynikami pewności." />
    <meta property="og:title" content="Auto-Detektor Kodowania" />
    <meta property="og:description" content="Auto-wykrywaj i dekoduj Base64, hex, binarny, Morse, ROT13, URL i HTML encodings." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/pl/narzedzia/encoding-detector/" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/pl/narzedzia/encoding-detector/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/narzedzia/encoding-detector/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/narzedzia/encoding-detector/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Auto-Detektor Kodowania",
      "description": "Automatycznie identyfikuj i dekoduj Base64, hex, binarny, Morse, ROT13, URL encoding i HTML entities.",
      "url": "https://776f6c6e6f.org/pl/narzedzia/encoding-detector/",
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Dowolny (przeglądarka)",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PLN" }
    })}</script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G932JG5N9Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (typeof window !== 'undefined' && localStorage.getItem('cookies-accepted') === 'true') {
        gtag('config', 'G-G932JG5N9Z');
      } else {
        document.addEventListener('cookies-accepted', function() {
          gtag('config', 'G-G932JG5N9Z');
        });
      }
    </script>
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation lang="pl" currentPath="/pl/narzedzia/encoding-detector/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ./detektor-kodowania --sprawdz-wszystko
          <span class="breadcrumb"> | <a href="/pl/narzedzia/">&larr; narzędzia</a></span>
        </div>

        <h1 class="page-title">Auto-Detektor Kodowania</h1>
        <p class="page-desc">
          Wklej zakodowany tekst, aby automatycznie zidentyfikować schemat kodowania i go zdekodować.
          Obsługuje Base64, szesnastkowy, binarny, kod Morse'a, ROT13, URL encoding i HTML entities.
          Całe przetwarzanie odbywa się lokalnie — bez serwera.
        </p>
        <div class="separator">-" wln</div>

        <EncodingDetector client:visible />

        <div class="tool-info">
          <h2>Przykłady Kodowań</h2>
          <table class="ref-table">
            <thead>
              <tr>
                <th>Kodowanie</th>
                <th>Oryginał</th>
                <th>Zakodowane</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Base64</td>
                <td class="mono">hello world</td>
                <td class="mono">aGVsbG8gd29ybGQ=</td>
              </tr>
              <tr>
                <td>Szesnastkowy</td>
                <td class="mono">wolno</td>
                <td class="mono">776f6c6e6f</td>
              </tr>
              <tr>
                <td>Binarny</td>
                <td class="mono">hi</td>
                <td class="mono">01101000 01101001</td>
              </tr>
              <tr>
                <td>Morse</td>
                <td class="mono">SOS</td>
                <td class="mono">... --- ...</td>
              </tr>
              <tr>
                <td>ROT13</td>
                <td class="mono">wolno</td>
                <td class="mono">jbyab</td>
              </tr>
              <tr>
                <td>URL Encoding</td>
                <td class="mono">hello world</td>
                <td class="mono">hello%20world</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="separator">-" wszwln</div>

        <nav class="page-nav-bottom">
          <a href="/pl/narzedzia/">&larr; Wszystkie narzędzia</a>
          <a href="/pl/narzedzia/unicode-inspector/">Inspektor Unicode</a>
          <a href="/pl/narzedzia/prompt-visibility/">Widoczność Promptów &rarr;</a>
        </nav>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS JEST ONLINE | <a href="/pl/donate/">$ wsparcie</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="pl" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title { font-size: 1.6rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .tool-info { margin: 2rem 0; }
  .tool-info h2 {
    font-size: 1rem;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .ref-table th, .ref-table td {
    border: 1px solid var(--border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .ref-table th {
    background: var(--bg-tertiary);
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .ref-table td { color: var(--text-secondary); }
  .mono { font-family: var(--font-mono); color: var(--text-primary); word-break: break-all; }

  .page-nav-bottom {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
  }
  .page-nav-bottom a { color: var(--accent); }
  .page-nav-bottom a:hover { text-decoration: none; opacity: 0.8; }
</style>
