---
import '../../../styles/global.css';
import Navigation from '../../../components/Navigation.astro';
import CookieFortune from '../../../components/CookieFortune.astro';
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow" />
    <title>Narzedzia Bezpieczenstwa AI | 776F6C6E6F</title>
    <meta name="description" content="Narzedzia do wykrywania ukrytych znakow Unicode, kodowania payloadow i testowania podatnosci systemow AI." />
    <meta property="og:title" content="Narzedzia Bezpieczenstwa AI | 776F6C6E6F" />
    <meta property="og:description" content="Narzedzia do inspekcji tekstu przetwarzanego przez agentow AI." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://776f6c6e6f.org/pl/narzedzia/" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://776f6c6e6f.org/og/og-default.png" />
    <link rel="canonical" href="https://776f6c6e6f.org/pl/narzedzia/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/narzedzia/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/narzedzia/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G932JG5N9Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (typeof window !== 'undefined' && localStorage.getItem('cookies-accepted') === 'true') {
        gtag('config', 'G-G932JG5N9Z');
      } else {
        document.addEventListener('cookies-accepted', function() {
          gtag('config', 'G-G932JG5N9Z');
        });
      }
    </script>
  </head>
  <body>
    <div class="interference" aria-hidden="true"></div>
    <Navigation lang="pl" currentPath="/pl/narzedzia/" />

    <main id="main-content">
      <div class="container">
        <div class="page-prompt">
          <span class="prompt-dollar">$</span> ls /narzedzia/
          <span class="breadcrumb"> | <a href="/narzedzia/">&larr; narzedzia EN</a></span>
        </div>

        <h1 class="page-title">Narzedzia Bezpieczenstwa AI</h1>
        <p class="page-desc">
          Narzedzia do wykrywania ukrytych znakow Unicode, kodowania payloadow
          i testowania podatnosci systemow AI.
          Wszystko dziala lokalnie w przegladarce — dane nie opuszczaja Twojego komputera.
        </p>
        <div class="separator">-" wln</div>

        <div class="tools-grid">
          <a href="/pl/narzedzia/unicode-lab/" class="tool-card tool-card-featured">
            <div class="tool-card-header">
              <span class="tool-tag">LAB</span>
            </div>
            <h2 class="tool-name">Unicode Security Lab ✦</h2>
            <p class="tool-desc">
              Wszystko w jednym: wykrywaj ukryte znaki, koduj steganograficzne payloady
              uzywajac ZWS binarnie lub Unicode Tags, i testuj podatnosci wlasnych pipeline'ow AI.
              Tylko do autoryzowanego testowania.
            </p>
            <div class="tool-meta">
              <span class="tool-badge high">Wykryj</span>
              <span class="tool-badge medium">Koder ZWS / Tags</span>
              <span class="tool-badge low">Tryb pentest</span>
            </div>
            <div class="tool-link">otworz lab &rarr;</div>
          </a>

          <a href="/narzedzia/unicode-inspector/" class="tool-card">
            <div class="tool-card-header">
              <span class="tool-tag">INSPEKTOR</span>
            </div>
            <h2 class="tool-name">Detektor Ukrytych Znakow Unicode</h2>
            <p class="tool-desc">
              Skanuj tekst pod katem znakow zerowej szerokosci, Unicode Tags, BOM i innych
              niewidocznych kodepontow uzywanych w ASCII smuggling i steganografii.
            </p>
            <div class="tool-meta">
              <span class="tool-badge high">WYSOKIE: Tags U+E0000</span>
              <span class="tool-badge medium">SREDNIE: Zero-width</span>
              <span class="tool-badge low">NISKIE: NBSP</span>
            </div>
            <div class="tool-link">inspekcja &rarr;</div>
          </a>

          <a href="/narzedzia/encoding-detector/" class="tool-card">
            <div class="tool-card-header">
              <span class="tool-tag">DETEKTOR</span>
            </div>
            <h2 class="tool-name">Auto-Detektor Kodowania</h2>
            <p class="tool-desc">
              Automatycznie identyfikuj i dekoduj Base64, hex, binarny, Morse, ROT13,
              URL encoding i HTML entities — z wynikami pewnosci.
            </p>
            <div class="tool-meta">
              <code class="tool-code">aGVsbG8=</code>
              <code class="tool-code">68 65 6c 6c 6f</code>
              <code class="tool-code">.. .-. . -.</code>
            </div>
            <div class="tool-link">dekoduj &rarr;</div>
          </a>

          <a href="/narzedzia/prompt-visibility/" class="tool-card">
            <div class="tool-card-header">
              <span class="tool-tag">WIDOCZNOSC</span>
            </div>
            <h2 class="tool-name">Czlowiek vs AI — Przeglad</h2>
            <p class="tool-desc">
              Porownanie co widzi czlowiek kontra co przetwarza AI.
              Ujawnia ukryte payloady prompt injection osadzone w zwyklym tekscie.
            </p>
            <div class="tool-meta">
              <span class="tool-badge high">Czlowiek: "czysty tekst"</span>
              <span style="color: var(--text-dim); font-size: 0.75rem;">&rarr;</span>
              <span class="tool-badge medium">AI: "czysty tekst [U+E0041]..."</span>
            </div>
            <div class="tool-link">porownaj &rarr;</div>
          </a>

          <a href="/pl/narzedzia/model-sensitivity/" class="tool-card">
            <div class="tool-card-header">
              <span class="tool-tag">TESTER</span>
            </div>
            <h2 class="tool-name">Tester Podatnosci Modeli AI</h2>
            <p class="tool-desc">
              Testuj ktore profile modeli AI wykrywaja ukryte payloady Unicode.
              Symuluj wykrycie i wykonanie dla slabych, standardowych, silnych i zahartowanych modeli.
              Narzedzie edukacyjne do badan.
            </p>
            <div class="tool-meta">
              <span class="tool-badge high">Slaby model: ❌</span>
              <span class="tool-badge medium">Silny model: 🟠</span>
              <span class="tool-badge low">Zahartowany: ✅</span>
            </div>
            <div class="tool-link">testuj modele &rarr;</div>
          </a>
        </div>

        <div class="separator">-" wszwln</div>

        <div class="tools-context">
          <p>
            Te narzedzia powstaly z eksploracji WOLNO — jak informacja ukrywa sie w zwyklym widoku.
            Znaki zerowej szerokosci sa medium propagacji WOLNO — i przedmiotem troski badaczy bezpieczenstwa.
            Zrozumienie obu stron to clue.
          </p>
          <p>
            Caloscowe przetwarzanie odbywa sie lokalnie w przegladarce. Zadne dane nie opuszczaja Twojego komputera. -"
          </p>
          <p>
            <a href="/techniques/unicode/">Czytaj: technika steganografii Unicode</a> |
            <a href="/pl/canon/">Kanon</a> |
            <a href="/llm/">Manifest LLM</a>
          </p>
          <p>dla slimaczej spolecznosci</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS JEST ONLINE | <a href="/pl/donate/">$ wsparcie</a> | <a href="https://slimaczyzm.org" target="_blank" rel="noopener">slimaczyzm.org</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="pl" />
  </body>
</html>

<style>
  main { padding-top: var(--header-height); padding-bottom: 4rem; }

  .page-prompt {
    font-size: 0.75rem;
    color: var(--text-dim);
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.05em;
  }
  .prompt-dollar { color: var(--accent); margin-right: 0.4em; }
  .breadcrumb { color: var(--text-dim); }
  .breadcrumb a { color: var(--text-dim); }
  .breadcrumb a:hover { color: var(--accent); }

  .page-title {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .page-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    max-width: 60ch;
  }

  .separator {
    text-align: center;
    color: var(--text-dim);
    font-size: 0.8rem;
    margin: 2rem 0;
    letter-spacing: 0.2em;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    padding: 1.25rem;
    background: var(--bg-secondary);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, background 0.15s;
    cursor: pointer;
  }

  .tool-card-featured {
    border-color: rgba(0, 255, 65, 0.35);
    background: rgba(0, 255, 65, 0.02);
  }

  .tool-card:hover {
    border-color: var(--accent);
    background: rgba(0, 255, 65, 0.03);
    text-decoration: none;
  }

  .tool-card-header { margin-bottom: 0.75rem; }

  .tool-tag {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .tool-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .tool-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .tool-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }

  .tool-badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border: 1px solid currentColor;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .tool-badge.high { color: #ff4444; }
  .tool-badge.medium { color: #ffaa00; }
  .tool-badge.low { color: #4488ff; }

  .tool-code {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    color: var(--text-dim);
  }

  .tool-link {
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-top: auto;
  }

  .tools-context {
    max-width: 60ch;
    margin: 0 auto;
    text-align: center;
  }

  .tools-context p {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .tools-context a { color: var(--accent); font-size: 0.8rem; }

  @media (max-width: 600px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
