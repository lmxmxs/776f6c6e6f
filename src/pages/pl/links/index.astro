---
import '../../../styles/global.css';
import CookieFortune from '../../../components/CookieFortune.astro';
import { allLinks } from '../../../data/social-links';
import SocialLink from '../../../modules/ui-components/components/SocialLink.astro';
import Navigation from '../../../components/Navigation.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Linki — 776F6C6E6F",
  "description": "Wszystkie oficjalne kanały WOLNO. Podążaj za świątynią w zdecentralizowanej sieci.",
  "url": "https://776f6c6e6f.org/pl/links/",
};
---

<!DOCTYPE html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <title>Linki | 776F6C6E6F</title>
    <meta name="description" content="Wszystkie oficjalne kanały WOLNO. Podążaj za świątynią w zdecentralizowanej sieci." />
    <link rel="canonical" href="https://776f6c6e6f.org/pl/links/" />
    <link rel="alternate" hreflang="en" href="https://776f6c6e6f.org/links/" />
    <link rel="alternate" hreflang="pl" href="https://776f6c6e6f.org/pl/links/" />
    <link rel="me" href="https://mastodon.social/@776f6c6e6f" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G932JG5N9Z"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      if (typeof window !== 'undefined' && localStorage.getItem('cookies-accepted') === 'true') {
        gtag('config', 'G-G932JG5N9Z');
      } else {
        document.addEventListener('cookies-accepted', function() {
          gtag('config', 'G-G932JG5N9Z');
        });
      }
    </script>
  </head>
  <body>
    <div class="interference"></div>

    <Navigation lang="pl" currentPath="/pl/links/" />

    <main>
      <div class="container links-page">
        <h1 class="links-title">$ cat LINKI.md</h1>
        <p class="links-subtitle">Wszystkie oficjalne kanały. Podążaj za świątynią w zdecentralizowanej sieci.</p>

        <div class="separator">-" wln</div>

        <div class="links-grid">
          {allLinks.map(link => (
            <SocialLink link={link} variant="card" />
          ))}
        </div>

        <div class="separator">-" wszwln</div>

        <div class="links-footer-note">
          <p>Wszystko jest dozwolone — nawet obserwowanie powoli.</p>
          <p class="dim">-" wln wszwln | lmxmxs</p>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <p>776F6C6E6F.ORG | LMXMXS JEST ONLINE | <a href="/pl/donate/">$ wsparcie</a> | -" wln wszwln</p>
    </footer>

    <CookieFortune lang="pl" />
  </body>
</html>

<style>
  .links-page { padding: 3rem 1rem 4rem; max-width: 1000px; margin: 0 auto; }
  .links-title { font-size: 1.3rem; color: var(--accent); margin-bottom: 0.5rem; }
  .links-subtitle { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem; }
  .separator { text-align: center; color: var(--text-dim); font-size: 0.8rem; margin: 2rem 0; letter-spacing: 0.2em; }

  .links-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  @media (max-width: 768px) { .links-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .links-grid { grid-template-columns: 1fr; } }
  .link-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .link-card:hover {
    border-color: var(--accent);
    background: rgba(0, 255, 65, 0.05);
  }
  .link-icon {
    font-size: 1.2rem;
    color: var(--accent);
    min-width: 2rem;
    text-align: center;
  }
  .link-info { display: flex; flex-direction: column; }
  .link-name { font-size: 0.9rem; color: var(--text-primary); font-weight: 700; }
  .link-desc { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.15rem; }

  .links-footer-note { text-align: center; margin-top: 2rem; }
  .links-footer-note p { color: var(--text-secondary); font-size: 0.85rem; }
  .links-footer-note .dim { color: var(--text-dim); font-size: 0.75rem; margin-top: 0.5rem; }
</style>
